---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';

const maintenanceDetails = [
  {
    title: "Seguridad Proactiva & Blindaje",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
    description: "Protegemos tu sitio contra ataques de fuerza bruta, malware y vulnerabilidades de día cero.",
    features: [
      "Escaneo de Malware diario en servidor y archivos.",
      "Firewall de Aplicación Web (WAF) configurado a medida.",
      "Protección contra ataques DDoS y spam en formularios.",
      "Actualizaciones críticas de parches de seguridad en < 24h.",
      "Certificados SSL Enterprise gestionados."
    ]
  },
  {
    title: "Optimización de Servidores & WPO",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>`,
    description: "No solo mantenemos, aceleramos. Tu web volará sobre infraestructura optimizada.",
    features: [
      "Configuración de caché avanzada a nivel de servidor (Redis/Varnish).",
      "Optimización de bases de datos para consultas ultra-rápidas.",
      "CDN Global (Content Delivery Network) integrada.",
      "Compresión de imágenes y assets sin pérdida de calidad.",
      "Monitoreo de Core Web Vitals constante."
    ]
  },
  {
    title: "Continuidad de Negocio",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 12a9 9 0 1 1-9-9c2.52 0 4.85.99 6.57 2.57L21 8M21 3v5h-5"/></svg>`,
    description: "Garantizamos que tu web nunca deje de funcionar, pase lo que pase.",
    features: [
      "Puntos de restauración (Backups) horarios y diarios.",
      "Almacenamiento de copias en nube externa segura.",
      "Garantía de recuperación completa en caso de desastre.",
      "Migraciones gratuitas entre servidores si el proyecto escala.",
      "Uptime Monitor 24/7 con alertas instantáneas."
    ]
  }
];

const maintenancePlans = [
  {
    name: "Pack Mini Web",
    price: "50€",
    period: "mes",
    badge: "Presencia Activa",
    description: "Ideal para landing pages y sitios de una sola página que requieren estabilidad profesional.",
    features: [
      "Hosting Premium SSD NVMe",
      "Dominio .es / .com incluido",
      "Certificado SSL Enterprise",
      "Actualizaciones de seguridad",
      "Soporte por correo (48h)"
    ],
    cta: "Contratar Mini",
    theme: "zinc"
  },
  {
    name: "Web Corporativa Pro",
    price: "120€",
    period: "mes",
    badge: "Más Vendido",
    description: "Gestión total para empresas que dependen de su web para captar clientes diariamente.",
    features: [
      "Hosting High-Performance",
      "1h de cambios/edición mensual",
      "SEO Local & GMB Management",
      "Backups cada 4 horas",
      "Soporte Prioritario (24h)",
      "Informes de rendimiento trimestrales"
    ],
    cta: "Elevar mi Negocio",
    theme: "emerald",
    popular: true
  },
  {
    name: "E-commerce / Media Pro",
    price: "250€",
    period: "mes",
    badge: "Máximo Rendimiento",
    description: "Diseñado para tiendas online, portales de noticias o webs con tráfico masivo.",
    features: [
      "Servidor Dedicado Optimizado",
      "Mantenimiento de Catálogo",
      "Seguridad Ultra-Blindada",
      "Revisiones de Conversión (CRO)",
      "WhatsApp Directo Soporte 24/7",
      "Gestión de pasarelas de pago"
    ],
    cta: "Gestionar Mi Web",
    theme: "teal"
  }
];
---

<BaseLayout
  title="Mantenimiento Web y Hosting en Almería | Seguridad Proactiva"
  description="Planes de mantenimiento web avanzado en Almería. Seguridad técnica, optimización de velocidad (WPO), hosting premium SSD y soporte especializado 24/7."
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Mantenimiento y Soporte Web",
    "provider": {
      "@type": "Organization",
      "name": "Platanito Rico",
      "url": "https://platanitorico.com"
    },
    "description": "Servicios de mantenimiento técnico, seguridad web y optimización de servidores en Almería.",
    "areaServed": {
      "@type": "State",
      "name": "Almería"
    },
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "Planes de Mantenimiento",
      "itemListElement": [
        {
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": "Seguridad Proactiva & Blindaje"
          }
        },
        {
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": "Optimización de Servidores & WPO"
          }
        }
      ]
    }
  }}
>
  <Header />

  <main class="pt-20">
    <!-- Hero Section -->
    <section class="relative min-h-[60vh] flex items-center justify-center overflow-hidden py-24 text-center">
      <div class="absolute inset-0 bg-grid-pattern opacity-10"></div>
      <div class="absolute inset-0 bg-gradient-to-b from-emerald-950/20 via-zinc-950/90 to-zinc-950"></div>
      
      <div class="container-premium relative z-10">
        <div class="badge-premium mb-8 inline-flex animate-fade-up">
          <span class="text-emerald-400 font-bold uppercase tracking-[0.2em] text-[10px]">Site Reliability Engineering</span>
        </div>
        <h1 class="heading-display mb-8 animate-fade-up stagger-1">
          Blindaje y Evolución
          <span class="block text-gradient mt-2">Para tu activo más valioso</span>
        </h1>
        <p class="text-xl text-zinc-400 max-w-3xl mx-auto mb-12 animate-fade-up stagger-2 leading-relaxed">
          No somos un servicio técnico tradicional. Somos tu **departamento técnico de élite**. Monitorizamos, protegemos y aceleramos tu web para que tú te centres en vender.
        </p>
        <div class="flex flex-col sm:flex-row justify-center gap-6 animate-fade-up stagger-3">
            <a href="#planes" class="btn-premium px-12 !bg-emerald-600 hover:!bg-emerald-700">Ver Planes de Mantenimiento</a>
            <a href="#detalles" class="btn-premium !bg-white/5 !border-white/10 px-12">¿Qué incluye nuestro soporte?</a>
        </div>
      </div>
    </section>

    <!-- Detailed Services Breakdown -->
    <section id="detalles" class="section-premium relative">
        <div class="container-premium">
            <div class="text-center mb-24">
                <h2 class="text-4xl font-black text-white mb-6">Mantenimiento de <span class="text-gradient">Grado Militar</span></h2>
                <p class="text-zinc-500 max-w-2xl mx-auto italic">
                    Analizamos más de 50 puntos de control cada hora para asegurar que tu presencia online sea inquebrantable.
                </p>
            </div>

            <div class="grid md:grid-cols-3 gap-12">
                {maintenanceDetails.map((detail, idx) => (
                    <div class="animate-fade-up" style={`animation-delay: ${idx * 0.1}s`}>
                        <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-emerald-500 to-teal-600 p-0.5 shadow-lg shadow-emerald-500/20 mb-8">
                            <div class="w-full h-full rounded-[14px] bg-zinc-950 flex items-center justify-center">
                                <Fragment set:html={detail.icon} />
                            </div>
                        </div>
                        <h3 class="text-2xl font-black text-white mb-4">{detail.title}</h3>
                        <p class="text-zinc-500 mb-8 text-sm leading-relaxed">{detail.description}</p>
                        <ul class="space-y-4">
                            {detail.features.map(feature => (
                                <li class="flex items-start gap-3 text-xs text-zinc-400">
                                    <svg class="w-4 h-4 text-emerald-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M5 13l4 4L19 7"/></svg>
                                    <span>{feature}</span>
                                </li>
                            ))}
                        </ul>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- Maintenance Plans (Consistent with Development Page) -->
    <section id="planes" class="section-premium bg-zinc-950 border-t border-white/5 relative overflow-hidden">
        <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-emerald-500/20 to-transparent"></div>
        
        <div class="container-premium text-center mb-20">
            <div class="badge-premium mb-6 bg-emerald-500/10 !text-emerald-400 !border-none">Inversión Mensual</div>
            <h2 class="text-5xl font-black text-white mb-6">Planes de <span class="text-gradient">Soporte Técnico</span></h2>
            <p class="text-zinc-500 max-w-2xl mx-auto text-lg leading-relaxed">Selecciona el nivel de protección y soporte que tu negocio merece.</p>
        </div>

        <div class="container-premium grid lg:grid-cols-3 gap-8 max-w-7xl mx-auto">
            {maintenancePlans.map((plan) => (
                <div class={`gradient-border-card group ${plan.popular ? 'scale-105 z-10' : ''}`}>
                    <div class={`gradient-border-card-inner p-10 flex flex-col h-full bg-zinc-900/40 relative ${plan.popular ? 'border-emerald-500/30' : ''}`}>
                        {plan.popular && (
                            <div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-emerald-600 text-white text-[9px] font-black px-4 py-1.5 rounded-full whitespace-nowrap">EL MÁS POPULAR</div>
                        )}
                        <h4 class="text-zinc-500 uppercase font-black tracking-tighter mb-4 text-xs">{plan.name}</h4>
                        <div class="text-5xl font-black text-white mb-2">{plan.price} <span class="text-base text-zinc-600 font-bold">/ {plan.period}</span></div>
                        <p class="text-emerald-400 text-[10px] font-bold mb-10 uppercase tracking-widest italic">{plan.badge}</p>
                        <p class="text-zinc-500 text-sm mb-8 leading-relaxed italic">{plan.description}</p>
                        
                        <ul class="space-y-4 mb-10 text-left flex-1 border-t border-white/10 pt-8">
                            {plan.features.map(li => (
                                <li class="flex items-start gap-4 text-sm text-zinc-300">
                                    <svg class="w-4 h-4 text-emerald-500 flex-shrink-0 mt-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M5 13l4 4L19 7"/></svg>
                                    {li}
                                </li>
                            ))}
                        </ul>
                        <a href="/#contacto" class={`btn-premium !py-4 w-full text-center ${plan.theme === 'emerald' ? 'bg-gradient-to-r from-emerald-600 to-teal-600 border-none' : plan.theme === 'teal' ? 'bg-zinc-800 hover:bg-zinc-700' : 'bg-zinc-800 hover:bg-zinc-700'}`}>
                            {plan.cta}
                        </a>
                    </div>
                </div>
            ))}
        </div>
    </section>

    <!-- Why Maintenance? FAQ-style Section -->
    <section class="py-24 relative overflow-hidden">
        <div class="container-premium">
            <div class="max-w-4xl mx-auto">
                <div class="grid md:grid-cols-2 gap-16">
                    <div>
                        <h2 class="text-3xl font-black text-white mb-8">¿Qué sucede en el <span class="text-emerald-400">mantenimiento real</span>?</h2>
                        <div class="space-y-8">
                            <div>
                                <h4 class="text-white font-bold mb-2">Monitorización de Salud</h4>
                                <p class="text-zinc-500 text-sm">No esperamos a que algo falle. Revisamos logs de servidor, errores 404 y latencia de base de datos en tiempo real.</p>
                            </div>
                            <div>
                                <h4 class="text-white font-bold mb-2">Higiene de Datos</h4>
                                <p class="text-zinc-500 text-sm">Limpiamos revisiones de posts, optimizamos tablas de SQL y eliminamos archivos temporales que ralentizan la carga.</p>
                            </div>
                            <div>
                                <h4 class="text-white font-bold mb-2">Protección de Reputación</h4>
                                <p class="text-zinc-500 text-sm">Evitamos que tu web entre en 'listas negras' de Google por infecciones de malware que tú ni siquiera sabías que tenías.</p>
                            </div>
                        </div>
                    </div>
                    <div class="relative">
                        <div class="absolute inset-0 bg-emerald-500/10 blur-[100px] rounded-full"></div>
                        <div class="relative p-8 rounded-3xl bg-white/[0.02] border border-white/5 backdrop-blur-md">
                            <h4 class="text-white font-black mb-6 uppercase tracking-widest text-xs">Métricas de Estabilidad</h4>
                            <div class="space-y-6">
                                <div class="flex justify-between items-center">
                                    <span class="text-zinc-400 text-sm">Uptime Garantizado</span>
                                    <span class="text-emerald-400 font-black">99.9%</span>
                                </div>
                                <div class="w-full h-1 bg-white/5 rounded-full overflow-hidden">
                                    <div class="h-full bg-emerald-500 w-[99.9%]"></div>
                                </div>
                                <div class="flex justify-between items-center">
                                    <span class="text-zinc-400 text-sm">Tiempo Respuesta Soporte</span>
                                    <span class="text-emerald-400 font-black">&lt; 4h</span>
                                </div>
                                <div class="w-full h-1 bg-white/5 rounded-full overflow-hidden">
                                    <div class="h-full bg-emerald-500 w-[95%]"></div>
                                </div>
                                <div class="flex justify-between items-center">
                                    <span class="text-zinc-400 text-sm">Reducción Riesgo Ataque</span>
                                    <span class="text-emerald-400 font-black">98%</span>
                                </div>
                                <div class="w-full h-1 bg-white/5 rounded-full overflow-hidden">
                                    <div class="h-full bg-emerald-500 w-[98%]"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Contact CTA -->
    <section id="contacto" class="section-premium text-center">
      <div class="container-premium">
        <div class="max-w-3xl mx-auto p-12 rounded-3xl bg-white/[0.02] border border-white/5 backdrop-blur-md">
          <h2 class="text-3xl font-black text-white mb-6">Blindamos tu éxito</h2>
          <p class="text-zinc-400 text-lg mb-8 italic">Una web abandonada es una web vulnerable. Asegura tu inversión con profesionales.</p>
          <a href="/#contacto" class="btn-premium px-12 group">
            <span class="flex items-center gap-2">
                Solicitar Auditoría de Seguridad Gratis
                <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </span>
          </a>
        </div>
      </div>
    </section>

  </main>
  
  <Footer />
</BaseLayout>
