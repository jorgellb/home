---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import Breadcrumb from '../components/common/Breadcrumb.astro';

// Obtener posts publicados (no drafts)
const allPosts = await getCollection('posts', ({ data }) => !data.draft);

// Ordenar por fecha de publicación (más reciente primero)
const posts = allPosts.sort((a, b) => 
  b.data.publishedAt.getTime() - a.data.publishedAt.getTime()
);

// Función para formatear la fecha
function formatDate(date: Date): string {
  return date.toLocaleDateString('es-ES', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  });
}

// Función para calcular tiempo de lectura estimado
function calculateReadingTime(content: string): number {
  const wordsPerMinute = 200;
  const wordCount = content.split(/\s+/).length;
  return Math.ceil(wordCount / wordsPerMinute);
}
---

<BaseLayout
  title="Blog de Tecnología y Digitalización | Platanito Rico"
  description="Artículos sobre tecnología, facturación electrónica, VERIFACTU, marketing digital y consejos para empresas y autónomos."
  type="website"
  keywords="blog tecnología, VERIFACTU, facturación electrónica, marketing digital, consejos empresas"
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "Blog",
    "name": "Blog Platanito Rico",
    "description": "Artículos sobre tecnología, facturación electrónica y marketing digital",
    "url": "https://platanitorico.com/blog",
    "publisher": {
      "@type": "Organization",
      "name": "Platanito Rico",
      "logo": {
        "@type": "ImageObject",
        "url": "https://platanitorico.com/imagenes/logo.png"
      }
    }
  }}
>
  <Header />
  
  <!-- Breadcrumb Navigation -->
  <Breadcrumb items={[
    { label: 'Inicio', href: '/' },
    { label: 'Blog' }
  ]} />

  <main class="pt-0">
    <!-- Hero Section -->
    <section class="relative py-24 lg:py-32 overflow-hidden bg-gradient-to-br from-slate-900 via-slate-800 to-orange-900">
      <!-- Background Pattern -->
      <div class="absolute inset-0 opacity-10">
        <div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.05)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.05)_1px,transparent_1px)] bg-[size:60px_60px]"></div>
      </div>
      
      <!-- Floating Orbs -->
      <div class="absolute top-20 left-10 w-72 h-72 bg-orange-500/20 rounded-full blur-[100px] animate-pulse"></div>
      <div class="absolute bottom-20 right-10 w-96 h-96 bg-amber-500/20 rounded-full blur-[120px] animate-pulse" style="animation-delay: 1s;"></div>
      
      <div class="container-premium relative z-10">
        <div class="max-w-4xl mx-auto text-center">
          <!-- Badge -->
          <div class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-white/10 backdrop-blur-md border border-white/20 mb-8">
            <span class="relative flex h-2.5 w-2.5">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-orange-400 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-orange-500"></span>
            </span>
            <span class="text-sm font-medium text-white/90">Actualizado regularmente</span>
          </div>
          
          <!-- Heading -->
          <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold text-white mb-8 leading-[1.1]">
            Blog de
            <span class="bg-gradient-to-r from-orange-400 via-amber-300 to-orange-400 bg-clip-text text-transparent"> Tecnología</span>
          </h1>
          
          <!-- Description -->
          <p class="text-xl md:text-2xl text-white/80 max-w-3xl mx-auto leading-relaxed">
            Artículos sobre <strong class="text-white">facturación electrónica, VERIFACTU, 
            marketing digital</strong> y consejos para empresas y autónomos.
          </p>
        </div>
      </div>
    </section>

    <!-- Blog Posts Grid -->
    <section class="py-24 lg:py-32 relative overflow-hidden bg-gradient-to-b from-slate-50 via-white to-slate-50">
      <!-- Background Elements -->
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_20%_30%,rgba(255,107,0,0.05)_0%,transparent_40%)]"></div>
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_80%_70%,rgba(255,165,0,0.04)_0%,transparent_40%)]"></div>
      
      <div class="container-premium relative z-10">
        {posts.length === 0 ? (
          <!-- No posts state -->
          <div class="text-center py-20">
            <div class="w-24 h-24 mx-auto mb-6 rounded-3xl bg-gradient-to-br from-orange-100 to-amber-100 flex items-center justify-center">
              <svg class="w-12 h-12 text-orange-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
              </svg>
            </div>
            <h2 class="text-2xl font-bold text-slate-900 mb-4">Próximamente nuevos artículos</h2>
            <p class="text-slate-500 max-w-md mx-auto">
              Estamos preparando contenido de valor sobre tecnología y digitalización para tu empresa.
            </p>
          </div>
        ) : (
          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
            {posts.map((post, index) => {
              const readingTime = post.data.readingTime || calculateReadingTime(post.body || '');
              
              return (
                <article 
                  class="group relative flex flex-col bg-white rounded-3xl border border-slate-200 overflow-hidden hover:shadow-2xl hover:shadow-orange-500/10 hover:-translate-y-2 transition-all duration-500"
                  style={`animation-delay: ${index * 0.1}s`}
                >
                  <!-- Gradient Top Border -->
                  <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-orange-500 via-amber-500 to-orange-500 transform scale-x-0 group-hover:scale-x-100 transition-transform duration-500"></div>
                  
                  <!-- Image Container -->
                  <div class="relative aspect-[16/10] overflow-hidden bg-gradient-to-br from-slate-100 to-slate-200">
                    {post.data.featuredImage ? (
                      <img 
                        src={post.data.featuredImage} 
                        alt={post.data.featuredImageAlt || post.data.title}
                        class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
                      />
                    ) : (
                      <div class="w-full h-full flex items-center justify-center">
                        <div class="text-center p-8">
                          <div class="w-20 h-20 mx-auto mb-4 rounded-2xl bg-gradient-to-br from-orange-100 to-amber-100 flex items-center justify-center">
                            <span class="text-4xl">📝</span>
                          </div>
                        </div>
                      </div>
                    )}
                    
                    <!-- Category Badge -->
                    {post.data.categories && post.data.categories.length > 0 && (
                      <div class="absolute top-4 left-4">
                        <span class="px-3 py-1.5 rounded-full bg-white/95 backdrop-blur-sm text-xs font-semibold text-orange-600 shadow-lg">
                          {post.data.categories[0]}
                        </span>
                      </div>
                    )}
                  </div>
                  
                  <!-- Content -->
                  <div class="flex-1 p-6 lg:p-8 flex flex-col">
                    <!-- Meta -->
                    <div class="flex items-center gap-4 text-xs text-slate-400 mb-4">
                      <span class="flex items-center gap-1.5">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                        </svg>
                        {formatDate(post.data.publishedAt)}
                      </span>
                      <span class="flex items-center gap-1.5">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        {readingTime} min lectura
                      </span>
                    </div>
                    
                    <!-- Title -->
                    <h2 class="text-xl lg:text-2xl font-bold text-slate-900 mb-3 group-hover:text-orange-600 transition-colors line-clamp-2">
                      <a href={`/blog/${post.data.slug}`} class="after:absolute after:inset-0">
                        {post.data.title}
                      </a>
                    </h2>
                    
                    <!-- Excerpt -->
                    <p class="text-slate-600 text-sm leading-relaxed mb-6 line-clamp-3 flex-1">
                      {post.data.excerpt}
                    </p>
                    
                    <!-- Tags -->
                    {post.data.tags && post.data.tags.length > 0 && (
                      <div class="flex flex-wrap gap-2 mb-6">
                        {post.data.tags.slice(0, 3).map((tag) => (
                          <span class="px-2.5 py-1 rounded-lg bg-slate-100 text-xs text-slate-600">
                            #{tag}
                          </span>
                        ))}
                      </div>
                    )}
                    
                    <!-- Read More -->
                    <div class="flex items-center gap-2 text-orange-600 font-semibold text-sm group/link">
                      <span>Leer artículo</span>
                      <svg class="w-4 h-4 group-hover/link:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                      </svg>
                    </div>
                  </div>
                </article>
              );
            })}
          </div>
        )}
      </div>
    </section>

    <!-- Newsletter CTA -->
    <section class="py-24 relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-orange-500 via-amber-500 to-orange-600"></div>
      
      <!-- Animated Background Pattern -->
      <div class="absolute inset-0 opacity-10">
        <div class="absolute inset-0 bg-[linear-gradient(45deg,transparent_25%,rgba(255,255,255,0.3)_50%,transparent_75%)] bg-[length:250%_250%] animate-pulse"></div>
      </div>
      
      <div class="container-premium relative z-10">
        <div class="max-w-3xl mx-auto text-center">
          <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/20 backdrop-blur-sm text-white text-sm font-medium mb-8">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
              <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z" />
              <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z" />
            </svg>
            Newsletter
          </div>
          
          <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-white mb-6">
            Recibe los mejores consejos
          </h2>
          <p class="text-xl text-white/90 mb-10 max-w-2xl mx-auto">
            Suscríbete para recibir artículos sobre tecnología, facturación electrónica 
            y estrategias de crecimiento para tu empresa.
          </p>
          
          <div class="flex flex-col sm:flex-row gap-4 justify-center max-w-lg mx-auto">
            <a 
              href="/contacto" 
              class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-white text-orange-600 font-bold rounded-full shadow-xl hover:shadow-2xl hover:-translate-y-1 transition-all duration-300"
            >
              Contactar para más información
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
          
          <p class="mt-6 text-sm text-white/70">
            Sin spam. Puedes darte de baja en cualquier momento.
          </p>
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
</BaseLayout>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
