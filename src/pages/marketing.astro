---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';

const marketingCategories = [
  {
    title: "SEM & Publicidad (PVP)",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>`,
    description: "Captación inmediata de clientes mediante campañas de pago optimizadas.",
    items: [
      { name: "Campaña Meta Ads (5 Img + 1 Video)", price: "450€" },
      { name: "Campaña Meta Ads (5 imágenes)", price: "350€" },
      { name: "Administración SEM Mensual", price: "300€" },
      { name: "Creación de Campaña SEM Pro", price: "300€" },
      { name: "Configuración Píxel & Conversiones", price: "180€" },
      { name: "Auditoría de Cuenta Publicitaria", price: "150€" }
    ]
  },
  {
    title: "SEO & Estrategia (PVP)",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>`,
    description: "Visibilidad a largo plazo. Dominamos los resultados de Google.",
    items: [
      { name: "Keyword Research Extendido", price: "320€" },
      { name: "Auditoría SEO Técnica Completa", price: "450€" },
      { name: "Estrategia Local My Business", price: "120€" },
      { name: "Optimización On-Page (Home)", price: "150€" },
      { name: "Plan de Link Building Mensual", price: "280€" },
      { name: "SEO Técnico Mensual (Mantenimiento)", price: "200€" }
    ]
  },
  {
    title: "Redes Sociales & Community",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>`,
    description: "Construimos comunidades fieles y humanas para tu marca.",
    items: [
      { name: "Plan de Social Media Estratégico", price: "400€" },
      { name: "Gestión 3 RRSS (12 contenidos)", price: "350€" },
      { name: "Gestión 2 RRSS (8 contenidos)", price: "250€" },
      { name: "Diseño de Parrilla Visual (Feed)", price: "180€" },
      { name: "Moderación de Comentarios & DM", price: "90€" },
      { name: "Informe de Métricas & Análisis", price: "60€" }
    ]
  },
  {
    title: "Email & Funnels",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 4h16v12a2 2 0 01-2 2H6a2 2 0 01-2-2V4z"/><path d="M22 6l-10 7L2 6"/></svg>`,
    description: "Ventas automatizadas y fidelización de base de datos.",
    items: [
      { name: "Diseño & Copy Newsletter", price: "80€/u" },
      { name: "Configuración CRM / Email Automático", price: "220€" },
      { name: "Lead Magnet (Ebook/Guía)", price: "150€" },
      { name: "Funnel de Ventas Básico", price: "400€" },
      { name: "Copywriting de Página de Ventas", price: "250€" }
    ]
  }
];
---

<BaseLayout
  title="Agencia de Marketing Digital en Almería | SEO, Ads y Redes Sociales"
  description="Consultoría de marketing digital en Almería. Precios transparentes en SEO, Meta Ads (Facebook/Instagram), Google Ads y gestión profesional de redes sociales."
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Marketing Digital",
    "provider": {
      "@type": "Organization",
      "name": "Platanito Rico",
      "url": "https://platanitorico.com"
    },
    "description": "Servicios de SEO, publicidad online (SEM) y gestión de redes sociales en Almería.",
    "areaServed": {
      "@type": "State",
      "name": "Almería"
    },
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "Catálogo de Marketing Digital",
      "itemListElement": [
        {
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": "Gestión de Meta Ads"
          }
        },
        {
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": "Auditoría SEO Técnica"
          }
        }
      ]
    }
  }}
>
  <Header />

  <main class="pt-20">
    <!-- Hero Section -->
    <section class="relative min-h-[60vh] flex items-center justify-center overflow-hidden py-24">
      <div class="absolute inset-0 bg-grid-pattern opacity-10"></div>
      <div class="absolute inset-0 bg-gradient-to-b from-indigo-950/20 via-zinc-950/90 to-zinc-950"></div>
      
      <div class="container-premium relative z-10 text-center">
        <div class="badge-premium mb-8 inline-flex animate-fade-up">
          <span class="text-indigo-400 font-bold uppercase tracking-[0.2em] text-[10px]">Data-Driven Marketing</span>
        </div>
        <h1 class="heading-display mb-8 animate-fade-up stagger-1">
          Marketing que multiplica,
          <span class="block text-gradient mt-2">No solo divide</span>
        </h1>
        <p class="text-xl text-zinc-400 max-w-3xl mx-auto mb-12 animate-fade-up stagger-2 leading-relaxed">
          Especialistas en <strong>Performance, SEO y Social Ads</strong>. Precios detallados para una colaboración honesta y enfocada a objetivos de facturación.
        </p>
        <div class="flex flex-col sm:flex-row justify-center gap-6 animate-fade-up stagger-3">
            <a href="#catalogo" class="btn-premium px-12 !bg-indigo-600 hover:!bg-indigo-700">Ver Lista de Precios</a>
            <a href="#packs" class="btn-premium !bg-emerald-500/10 !border-emerald-500/20 !text-emerald-400 px-12">Packs de Crecimiento</a>
        </div>
      </div>
    </section>

    <!-- Results/Data Strip -->
    <section class="py-16 bg-zinc-900/40 relative border-y border-white/5">
        <div class="container-premium">
            <div class="max-w-4xl mx-auto grid md:grid-cols-2 gap-12 items-center">
                <div>
                    <h2 class="text-2xl font-bold text-white mb-6">Tu Socio en <span class="text-indigo-400">Escalabilidad Digital</span></h2>
                    <p class="text-zinc-400 leading-relaxed mb-4 text-sm">
                        No somos una agencia de marketing al uso. Nos centramos en el <strong>ROI (Retorno de Inversión)</strong>. Cada euro invertido en nuestras estrategias debe traducirse en visibilidad, leads y ventas reales para tu negocio.
                    </p>
                    <div class="flex flex-wrap gap-3">
                        <span class="px-3 py-1 rounded-full bg-white/5 border border-white/10 text-[10px] text-zinc-500 font-bold uppercase tracking-wider">Meta Ads Almería</span>
                        <span class="px-3 py-1 rounded-full bg-white/5 border border-white/10 text-[10px] text-zinc-500 font-bold uppercase tracking-wider">SEO Estratégico</span>
                        <span class="px-3 py-1 rounded-full bg-white/5 border border-white/10 text-[10px] text-zinc-500 font-bold uppercase tracking-wider">Performance</span>
                    </div>
                </div>
                <div class="grid grid-cols-2 gap-4 text-center">
                    <div class="p-6 rounded-2xl bg-white/[0.02] border border-white/5">
                        <p class="text-3xl font-black text-white mb-1">x3.5</p>
                        <p class="text-[10px] text-zinc-500 uppercase tracking-widest font-bold">ROI Medio Ads</p>
                    </div>
                    <div class="p-6 rounded-2xl bg-white/[0.02] border border-white/5">
                        <p class="text-3xl font-black text-indigo-400 mb-1">+40%</p>
                        <p class="text-[10px] text-zinc-500 uppercase tracking-widest font-bold">Conversión Web</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Complete Catalog -->
    <section id="catalogo" class="section-premium relative">
      <div class="container-premium">
        <div class="text-center mb-24">
            <h2 class="text-5xl font-black text-white mb-6">Lista de <span class="text-gradient">Tarifas Marketing</span></h2>
            <p class="text-zinc-500 max-w-2xl mx-auto italic">
                Precios base por servicio profesional. Los costes de presupuesto publicitario (ad spend) se pagan directamente a las plataformas.
            </p>
        </div>

        <div class="space-y-32">
            {marketingCategories.map((cat, idx) => (
                <div class="animate-fade-up" style={`animation-delay: ${idx * 0.1}s`}>
                    <div class="flex items-center gap-6 mb-12">
                        <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-indigo-500 to-purple-600 p-0.5 shadow-lg shadow-indigo-500/20">
                            <div class="w-full h-full rounded-[14px] bg-zinc-950 flex items-center justify-center">
                                <Fragment set:html={cat.icon} />
                            </div>
                        </div>
                        <div>
                            <h3 class="text-3xl font-black text-white mb-2">{cat.title}</h3>
                            <p class="text-zinc-500">{cat.description}</p>
                        </div>
                    </div>

                    <div class="grid md:grid-cols-2 gap-x-12 gap-y-4">
                        {cat.items.map(item => (
                            <div class="flex justify-between items-center py-4 border-b border-white/5 group hover:bg-white/[0.02] px-4 rounded-lg transition-all">
                                <span class="text-sm text-zinc-400 group-hover:text-white transition-colors">{item.name}</span>
                                <div class="flex items-center gap-4">
                                    <span class="text-xs font-bold text-zinc-500 uppercase tracking-widest">Inversión</span>
                                    <span class="text-lg font-black text-white">{item.price}</span>
                                </div>
                            </div>
                        ))}
                    </div>
                </div>
            ))}
        </div>
      </div>
    </section>

    <!-- Saving Hub -->
    <section id="packs" class="section-premium bg-zinc-950 border-t border-white/5 relative overflow-hidden">
        <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-indigo-500/20 to-transparent"></div>
        
        <div class="container-premium text-center mb-24">
            <div class="badge-premium mb-6 bg-emerald-500/10 !text-emerald-400 !border-none">Packs Estratégicos</div>
            <h2 class="text-5xl font-black text-white mb-6">Packs de <span class="text-gradient">Impacto Mensual</span></h2>
            <p class="text-zinc-500 max-w-2xl mx-auto text-lg leading-relaxed">Externaliza tu departamento de marketing y ahorra hasta un <strong>40% mensual</strong> comparando servicios sueltos.</p>
        </div>

        <div class="container-premium grid md:grid-cols-2 gap-12 max-w-5xl mx-auto">
             <!-- Pack Growth Standard -->
            <div class="gradient-border-card group relative">
                <div class="gradient-border-card-inner p-12 flex flex-col h-full bg-zinc-900/40 relative">
                    <h4 class="text-zinc-500 uppercase font-black tracking-tighter mb-4 text-sm">Pack Growth Digital</h4>
                    <div class="text-6xl font-black text-white mb-2">490€ <span class="text-lg text-zinc-600 font-bold">/ mes</span></div>
                    <p class="text-emerald-400 text-xs font-bold mb-10 uppercase tracking-widest italic">Visibilidad & Ventas</p>
                    
                    <ul class="space-y-6 mb-12 text-left flex-1 border-t border-white/10 pt-10">
                        {[
                            "Administración SEM (Google & Meta)",
                            "Gestión de 2 Redes Sociales",
                            "8 Diseños Creativos Mensuales",
                            "1 Newsletter / Email Mensual",
                            "Dashboard de Métricas 24/7"
                        ].map(li => (
                            <li class="flex items-start gap-4 text-sm text-zinc-400 italic">
                                <div class="w-5 h-5 rounded-full bg-emerald-500/20 flex items-center justify-center flex-shrink-0 mt-0.5">
                                    <svg class="w-3 h-3 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="4"><path d="M5 13l4 4L19 7"/></svg>
                                </div>
                                {li}
                            </li>
                        ))}
                    </ul>
                    <a href="/#contacto" class="btn-premium !py-5 w-full !bg-indigo-600 hover:!bg-indigo-700">Contratar Growth</a>
                </div>
            </div>

            <!-- Pack Scale VIP -->
            <div class="gradient-border-card group">
                <div class="gradient-border-card-inner p-12 flex flex-col h-full bg-zinc-950/60 relative border-indigo-500/20">
                    <div class="absolute -top-4 right-8 bg-indigo-600 text-white text-[10px] font-black px-5 py-2 rounded-full shadow-lg shadow-indigo-600/30">MÁXIMA ESCALABILIDAD</div>
                    <h4 class="text-indigo-400 uppercase font-black tracking-tighter mb-4 text-sm">Pack Scale VIP 360</h4>
                    <div class="text-6xl font-black text-white mb-2">890€ <span class="text-lg text-zinc-600 font-bold">/ mes</span></div>
                    <p class="text-emerald-400 text-xs font-bold mb-10 uppercase tracking-widest italic">Dominación Total del Mercado</p>
                    
                    <ul class="space-y-6 mb-12 text-left flex-1 border-t border-white/10 pt-10">
                        {[
                            "Estrategia SEM Avanzada (Multi-Canal)",
                            "SEO Mensual (Técnico + Contenidos)",
                            "Gestión de 4 Redes Sociales + Reels",
                            "Email Marketing & Automatización",
                            "Reunión Estratégica Quincenal",
                            "Copywriting para Landing Pages"
                        ].map(li => (
                            <li class="flex items-start gap-4 text-sm text-zinc-300">
                                <div class="w-5 h-5 rounded-full bg-indigo-500/20 flex items-center justify-center flex-shrink-0 mt-0.5">
                                    <svg class="w-3 h-3 text-indigo-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="4"><path d="M5 13l4 4L19 7"/></svg>
                                </div>
                                {li}
                            </li>
                        ))}
                    </ul>
                    <a href="/#contacto" class="btn-premium !py-5 w-full bg-gradient-to-r from-indigo-600 via-purple-600 to-purple-800 border-none shadow-xl shadow-indigo-500/20">Activar Scale VIP</a>
                </div>
            </div>
        </div>
    </section>

    <!-- Contact CTA -->
    <section id="contacto" class="section-premium text-center">
      <div class="container-premium">
        <div class="max-w-3xl mx-auto p-12 rounded-3xl bg-white/[0.02] border border-white/5 backdrop-blur-md">
          <h2 class="text-3xl font-black text-white mb-6">¿Quieres vender más?</h2>
          <p class="text-zinc-400 text-lg mb-8 italic">Analizamos tu tráfico, tu competencia y tus márgenes para crear la estrategia perfectca.</p>
          <a href="/#contacto" class="btn-premium px-12 group">
            <span class="flex items-center gap-2">
                Solicitar Consultoría Gratis
                <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </span>
          </a>
        </div>
      </div>
    </section>

  </main>
  
  <Footer />
</BaseLayout>
