---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import Breadcrumb from '../../components/common/Breadcrumb.astro';

// Generate static paths for all posts
export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  
  return posts.map((post) => ({
    params: { slug: post.data.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

// Función para formatear la fecha
function formatDate(date: Date): string {
  return date.toLocaleDateString('es-ES', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  });
}

// Calcular tiempo de lectura
function calculateReadingTime(content: string): number {
  const wordsPerMinute = 200;
  const wordCount = content.split(/\s+/).length;
  return Math.ceil(wordCount / wordsPerMinute);
}

const readingTime = post.data.readingTime || calculateReadingTime(post.body || '');

// Schema.org Article markup
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": post.data.title,
  "description": post.data.excerpt,
  "author": {
    "@type": "Organization",
    "name": post.data.author || "Platanito Rico"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Platanito Rico",
    "logo": {
      "@type": "ImageObject",
      "url": "https://platanitorico.com/imagenes/logo.png"
    }
  },
  "datePublished": post.data.publishedAt.toISOString(),
  "dateModified": (post.data.updatedAt || post.data.publishedAt).toISOString(),
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `https://platanitorico.com/blog/${post.data.slug}`
  },
  ...(post.data.featuredImage && {
    "image": {
      "@type": "ImageObject",
      "url": post.data.featuredImage
    }
  })
};
---

<BaseLayout
  title={post.data.seo?.title || `${post.data.title} | Blog Platanito Rico`}
  description={post.data.seo?.description || post.data.excerpt}
  type="article"
  keywords={post.data.seo?.keywords?.join(', ') || post.data.tags?.join(', ')}
  image={post.data.seo?.image || post.data.featuredImage}
  jsonLd={articleSchema}
>
  <Header />
  
  <!-- Breadcrumb Navigation -->
  <Breadcrumb items={[
    { label: 'Inicio', href: '/' },
    { label: 'Blog', href: '/blog' },
    { label: post.data.title }
  ]} />

  <main class="pt-0">
    <!-- Article Hero -->
    <section class="relative py-16 lg:py-24 overflow-hidden bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900">
      <!-- Background Pattern -->
      <div class="absolute inset-0 opacity-5">
        <div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.1)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.1)_1px,transparent_1px)] bg-[size:40px_40px]"></div>
      </div>
      
      <!-- Decorative Elements -->
      <div class="absolute top-0 right-0 w-96 h-96 bg-orange-500/10 rounded-full blur-[120px]"></div>
      <div class="absolute bottom-0 left-0 w-72 h-72 bg-amber-500/10 rounded-full blur-[100px]"></div>
      
      <div class="container-premium relative z-10">
        <div class="max-w-4xl mx-auto">
          <!-- Back Link -->
          <a 
            href="/blog" 
            class="inline-flex items-center gap-2 text-white/60 hover:text-white mb-8 transition-colors group"
          >
            <svg class="w-5 h-5 group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            Volver al blog
          </a>
          
          <!-- Categories -->
          {post.data.categories && post.data.categories.length > 0 && (
            <div class="flex flex-wrap gap-2 mb-6">
              {post.data.categories.map((category) => (
                <span class="px-4 py-1.5 rounded-full bg-orange-500/20 text-orange-300 text-sm font-medium border border-orange-500/30">
                  {category}
                </span>
              ))}
            </div>
          )}
          
          <!-- Title -->
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-8 leading-tight">
            {post.data.title}
          </h1>
          
          <!-- Meta -->
          <div class="flex flex-wrap items-center gap-6 text-white/70">
            <!-- Author -->
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-full bg-gradient-to-br from-orange-400 to-amber-500 flex items-center justify-center text-white font-bold text-sm">
                {post.data.author?.charAt(0) || 'P'}
              </div>
              <span class="font-medium">{post.data.author || 'Platanito Rico'}</span>
            </div>
            
            <!-- Date -->
            <div class="flex items-center gap-2">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
              <span>{formatDate(post.data.publishedAt)}</span>
            </div>
            
            <!-- Reading Time -->
            <div class="flex items-center gap-2">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <span>{readingTime} min de lectura</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Featured Image -->
    {post.data.featuredImage && (
      <section class="relative -mt-8 z-10">
        <div class="container-premium">
          <div class="max-w-5xl mx-auto">
            <div class="relative rounded-3xl overflow-hidden shadow-2xl shadow-slate-900/20">
              <img 
                src={post.data.featuredImage} 
                alt={post.data.featuredImageAlt || post.data.title}
                class="w-full aspect-[21/9] object-cover"
              />
            </div>
          </div>
        </div>
      </section>
    )}

    <!-- Article Content -->
    <article class="py-16 lg:py-24 relative overflow-hidden bg-white">
      <div class="container-premium">
        <div class="max-w-3xl mx-auto">
          <!-- Article Body -->
          <div class="prose prose-lg prose-slate max-w-none">
            <Content />
          </div>
          
          <!-- Tags -->
          {post.data.tags && post.data.tags.length > 0 && (
            <div class="mt-16 pt-8 border-t border-slate-200">
              <h3 class="text-sm font-bold text-slate-400 uppercase tracking-wider mb-4">Etiquetas</h3>
              <div class="flex flex-wrap gap-2">
                {post.data.tags.map((tag) => (
                  <span class="px-4 py-2 rounded-xl bg-slate-100 text-slate-700 text-sm font-medium hover:bg-orange-100 hover:text-orange-700 transition-colors cursor-default">
                    #{tag}
                  </span>
                ))}
              </div>
            </div>
          )}
          
          <!-- Share -->
          <div class="mt-12 pt-8 border-t border-slate-200">
            <h3 class="text-sm font-bold text-slate-400 uppercase tracking-wider mb-4">Compartir</h3>
            <div class="flex gap-3">
              <a 
                href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(post.data.title)}&url=${encodeURIComponent(`https://platanitorico.com/blog/${post.data.slug}`)}`}
                target="_blank"
                rel="noopener noreferrer"
                class="w-12 h-12 rounded-xl bg-slate-100 flex items-center justify-center text-slate-600 hover:bg-black hover:text-white transition-all"
                aria-label="Compartir en X"
              >
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                </svg>
              </a>
              <a 
                href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(`https://platanitorico.com/blog/${post.data.slug}`)}`}
                target="_blank"
                rel="noopener noreferrer"
                class="w-12 h-12 rounded-xl bg-slate-100 flex items-center justify-center text-slate-600 hover:bg-blue-600 hover:text-white transition-all"
                aria-label="Compartir en LinkedIn"
              >
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
              </a>
              <a 
                href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(`https://platanitorico.com/blog/${post.data.slug}`)}`}
                target="_blank"
                rel="noopener noreferrer"
                class="w-12 h-12 rounded-xl bg-slate-100 flex items-center justify-center text-slate-600 hover:bg-blue-800 hover:text-white transition-all"
                aria-label="Compartir en Facebook"
              >
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                </svg>
              </a>
              <button 
                onclick="navigator.clipboard.writeText(window.location.href); alert('Enlace copiado al portapapeles');"
                class="w-12 h-12 rounded-xl bg-slate-100 flex items-center justify-center text-slate-600 hover:bg-orange-500 hover:text-white transition-all"
                aria-label="Copiar enlace"
              >
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3" />
                </svg>
              </button>
            </div>
          </div>
        </div>
      </div>
    </article>

    <!-- CTA Section -->
    <section class="py-24 relative overflow-hidden bg-gradient-to-br from-slate-50 to-white">
      <!-- Background Elements -->
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_70%,rgba(255,107,0,0.05)_0%,transparent_50%)]"></div>
      
      <div class="container-premium relative z-10">
        <div class="max-w-4xl mx-auto">
          <div class="relative p-10 md:p-16 rounded-3xl bg-gradient-to-br from-slate-900 to-slate-800 overflow-hidden shadow-2xl shadow-slate-900/20">
            <!-- Decorative Elements -->
            <div class="absolute top-0 right-0 w-64 h-64 bg-orange-500/20 rounded-full blur-[100px]"></div>
            <div class="absolute bottom-0 left-0 w-48 h-48 bg-amber-500/20 rounded-full blur-[80px]"></div>
            
            <div class="relative text-center">
              <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">
                ¿Necesitas ayuda con tu empresa?
              </h2>
              <p class="text-xl text-slate-300 mb-10 max-w-2xl mx-auto">
                En Platanito Rico te ayudamos con desarrollo web, marketing digital 
                y soluciones tecnológicas para hacer crecer tu negocio.
              </p>
              
              <div class="flex flex-col sm:flex-row gap-4 justify-center">
                <a 
                  href="/contacto"
                  class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-gradient-to-r from-orange-500 to-amber-500 text-white font-bold rounded-full shadow-xl shadow-orange-500/30 hover:shadow-2xl hover:-translate-y-1 transition-all duration-300"
                >
                  Contactar
                  <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                  </svg>
                </a>
                <a 
                  href="/desarrollo-web"
                  class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-white/10 text-white font-bold rounded-full border border-white/20 hover:bg-white/20 transition-all duration-300"
                >
                  Ver servicios
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- More Articles -->
    <section class="py-24 relative overflow-hidden bg-white">
      <div class="container-premium">
        <div class="max-w-5xl mx-auto">
          <div class="flex items-center justify-between mb-12">
            <h2 class="text-3xl font-bold text-slate-900">
              Más artículos
            </h2>
            <a 
              href="/blog" 
              class="inline-flex items-center gap-2 text-orange-600 font-semibold hover:text-orange-700 transition-colors group"
            >
              Ver todo el blog
              <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
          
          <div class="grid md:grid-cols-2 gap-8">
            <a 
              href="/blog"
              class="group p-8 rounded-3xl bg-slate-50 border border-slate-200 hover:border-orange-300 hover:shadow-xl hover:-translate-y-1 transition-all duration-300"
            >
              <div class="flex items-start gap-4">
                <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-orange-100 to-amber-100 flex items-center justify-center flex-shrink-0 group-hover:scale-110 transition-transform">
                  <svg class="w-7 h-7 text-orange-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
                  </svg>
                </div>
                <div>
                  <h3 class="text-xl font-bold text-slate-900 mb-2 group-hover:text-orange-600 transition-colors">
                    Explorar todos los artículos
                  </h3>
                  <p class="text-slate-600">
                    Descubre más contenido sobre tecnología, facturación electrónica y estrategias de crecimiento.
                  </p>
                </div>
              </div>
            </a>
            
            <a 
              href="/contacto"
              class="group p-8 rounded-3xl bg-gradient-to-br from-orange-500 to-amber-500 text-white hover:shadow-xl hover:shadow-orange-500/30 hover:-translate-y-1 transition-all duration-300"
            >
              <div class="flex items-start gap-4">
                <div class="w-14 h-14 rounded-2xl bg-white/20 flex items-center justify-center flex-shrink-0 group-hover:scale-110 transition-transform">
                  <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
                  </svg>
                </div>
                <div>
                  <h3 class="text-xl font-bold mb-2">
                    ¿Tienes dudas?
                  </h3>
                  <p class="text-white/90">
                    Contacta con nosotros y te ayudaremos a resolver cualquier pregunta sobre VERIFACTU o servicios digitales.
                  </p>
                </div>
              </div>
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
</BaseLayout>

<style is:global>
  /* Prose Styles for Article Content */
  .prose h2 {
    font-size: 1.875rem;
    font-weight: 700;
    color: #0f172a;
    margin-top: 3rem;
    margin-bottom: 1.25rem;
    line-height: 1.2;
  }
  
  .prose h3 {
    font-size: 1.5rem;
    font-weight: 600;
    color: #1e293b;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    line-height: 1.3;
  }
  
  .prose h4 {
    font-size: 1.25rem;
    font-weight: 600;
    color: #334155;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  
  .prose p {
    margin-bottom: 1.5rem;
    line-height: 1.8;
    color: #475569;
  }
  
  .prose strong {
    color: #0f172a;
    font-weight: 600;
  }
  
  .prose ul, .prose ol {
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
  }
  
  .prose li {
    margin-bottom: 0.5rem;
    line-height: 1.7;
    color: #475569;
  }
  
  .prose ul li {
    list-style-type: disc;
  }
  
  .prose ol li {
    list-style-type: decimal;
  }
  
  .prose a {
    color: #ea580c;
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color 0.2s;
  }
  
  .prose a:hover {
    color: #c2410c;
  }
  
  .prose blockquote {
    border-left: 4px solid #f97316;
    padding-left: 1.5rem;
    margin: 2rem 0;
    font-style: italic;
    color: #475569;
  }
  
  .prose hr {
    border: none;
    border-top: 1px solid #e2e8f0;
    margin: 3rem 0;
  }
  
  .prose table {
    width: 100%;
    border-collapse: collapse;
    margin: 2rem 0;
    font-size: 0.9375rem;
  }
  
  .prose th {
    background: #f8fafc;
    padding: 0.75rem 1rem;
    text-align: left;
    font-weight: 600;
    color: #0f172a;
    border-bottom: 2px solid #e2e8f0;
  }
  
  .prose td {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid #e2e8f0;
    color: #475569;
  }
  
  .prose tr:hover td {
    background: #f8fafc;
  }
  
  .prose code {
    background: #f1f5f9;
    padding: 0.25rem 0.5rem;
    border-radius: 0.375rem;
    font-size: 0.875em;
    color: #ea580c;
    font-family: ui-monospace, SFMono-Regular, "SF Mono", Menlo, Consolas, monospace;
  }
  
  .prose pre {
    background: #1e293b;
    padding: 1.5rem;
    border-radius: 1rem;
    overflow-x: auto;
    margin: 2rem 0;
  }
  
  .prose pre code {
    background: transparent;
    padding: 0;
    color: #e2e8f0;
    font-size: 0.875rem;
  }
  
  /* Highlight Box */
  .prose > div[class*="bg-"] {
    border-radius: 1rem;
    padding: 1.5rem;
    margin: 2rem 0;
  }
</style>
