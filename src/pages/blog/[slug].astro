---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import Breadcrumb from '../../components/common/Breadcrumb.astro';

// Generate static paths for all posts
export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  
  return posts.map((post) => ({
    params: { slug: post.data.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

// Función para formatear la fecha
function formatDate(date: Date): string {
  return date.toLocaleDateString('es-ES', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  });
}

// Calcular tiempo de lectura
function calculateReadingTime(content: string): number {
  const wordsPerMinute = 200;
  const wordCount = content.split(/\s+/).length;
  return Math.ceil(wordCount / wordsPerMinute);
}

const readingTime = post.data.readingTime || calculateReadingTime(post.body || '');

// Schema.org Article markup
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": post.data.title,
  "description": post.data.excerpt,
  "author": {
    "@type": "Organization",
    "name": post.data.author || "Platanito Rico"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Platanito Rico",
    "logo": {
      "@type": "ImageObject",
      "url": "https://platanitorico.com/imagenes/logo.png"
    }
  },
  "datePublished": post.data.publishedAt.toISOString(),
  "dateModified": (post.data.updatedAt || post.data.publishedAt).toISOString(),
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `https://platanitorico.com/blog/${post.data.slug}`
  },
  ...(post.data.featuredImage && {
    "image": {
      "@type": "ImageObject",
      "url": post.data.featuredImage
    }
  })
};
---

<BaseLayout
  title={post.data.seo?.title || `${post.data.title} | Blog Platanito Rico`}
  description={post.data.seo?.description || post.data.excerpt}
  type="article"
  keywords={post.data.seo?.keywords?.join(', ') || post.data.tags?.join(', ')}
  image={post.data.seo?.image || post.data.featuredImage}
  jsonLd={articleSchema}
>
  <Header />
  
  <!-- Breadcrumb Navigation -->
  <Breadcrumb items={[
    { label: 'Inicio', href: '/' },
    { label: 'Blog', href: '/blog' },
    { label: post.data.title }
  ]} />

  <main class="pt-0 bg-background">
    <!-- Article Hero -->
    <section class="relative py-20 lg:py-32 overflow-hidden bg-background">
      <!-- Background Elements -->
      <div class="absolute inset-0 bg-grid-pattern opacity-40"></div>
      
      <!-- Decorative Orbs -->
      <div class="absolute -top-24 -right-24 w-96 h-96 bg-yellow-400/20 rounded-full blur-[120px] animate-glow-pulse"></div>
      <div class="absolute -bottom-24 -left-24 w-72 h-72 bg-nature-400/10 rounded-full blur-[100px] animate-glow-pulse stagger-2"></div>
      
      <div class="container-premium relative z-10">
        <div class="max-w-4xl">
          <!-- Back Link -->
          <a 
            href="/blog" 
            class="inline-flex items-center gap-2 text-dark-800/60 hover:text-dark-800 mb-12 transition-colors group font-medium"
          >
            <svg class="w-5 h-5 group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            Volver al blog
          </a>
          
          <!-- Categories -->
          {post.data.categories && post.data.categories.length > 0 && (
            <div class="flex flex-wrap gap-3 mb-8">
              {post.data.categories.map((category) => (
                <span class="px-5 py-2 rounded-full bg-white border border-dark-600/10 text-dark-700 text-sm font-bold tracking-wide uppercase">
                  {category}
                </span>
              ))}
            </div>
          )}
          
          <!-- Title -->
          <h1 class="text-5xl md:text-6xl lg:text-7xl font-display text-dark-900 mb-10 leading-[0.9] tracking-tight">
            {post.data.title}
          </h1>
          
          <!-- Meta -->
          <div class="flex flex-wrap items-center gap-8 text-dark-600">
            <!-- Author -->
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 rounded-full bg-yellow-400 flex items-center justify-center text-dark-900 font-display text-xl border-2 border-dark-900/5">
                {post.data.author?.charAt(0) || 'P'}
              </div>
              <span class="font-bold text-dark-800">{post.data.author || 'Platanito Rico'}</span>
            </div>
            
            <!-- Date -->
            <div class="flex items-center gap-2.5">
              <svg class="w-5 h-5 opacity-60" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
              <span class="font-medium">{formatDate(post.data.publishedAt)}</span>
            </div>
            
            <!-- Reading Time -->
            <div class="flex items-center gap-2.5">
              <svg class="w-5 h-5 opacity-60" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <span class="font-medium">{readingTime} min de lectura</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Featured Image -->
    {post.data.featuredImage && (
      <section class="relative -mt-10 lg:-mt-16 z-10">
        <div class="container-premium">
          <div class="max-w-6xl mx-auto">
            <div class="relative rounded-[2rem] lg:rounded-[3rem] overflow-hidden shadow-2xl border-4 border-white">
              <img 
                src={post.data.featuredImage} 
                alt={post.data.featuredImageAlt || post.data.title}
                class="w-full aspect-[21/9] object-cover"
              />
            </div>
          </div>
        </div>
      </section>
    )}

    <!-- Article Content -->
    <article class="py-16 lg:py-24 relative overflow-hidden bg-white">
      <div class="container-premium">
        <div class="max-w-3xl mx-auto">
          <!-- Article Body -->
          <div class="prose prose-lg prose-slate max-w-none">
            <Content />
          </div>
          
          <!-- Tags -->
          {post.data.tags && post.data.tags.length > 0 && (
            <div class="mt-16 pt-8 border-t border-slate-200">
              <h3 class="text-sm font-bold text-slate-400 uppercase tracking-wider mb-4">Etiquetas</h3>
              <div class="flex flex-wrap gap-2">
                {post.data.tags.map((tag) => (
                  <span class="px-4 py-2 rounded-xl bg-slate-100 text-slate-700 text-sm font-medium hover:bg-orange-100 hover:text-orange-700 transition-colors cursor-default">
                    #{tag}
                  </span>
                ))}
              </div>
            </div>
          )}
          
          <!-- Share -->
          <div class="mt-12 pt-8 border-t border-slate-200">
            <h3 class="text-sm font-bold text-slate-400 uppercase tracking-wider mb-4">Compartir</h3>
            <div class="flex gap-3">
              <a 
                href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(post.data.title)}&url=${encodeURIComponent(`https://platanitorico.com/blog/${post.data.slug}`)}`}
                target="_blank"
                rel="noopener noreferrer"
                class="w-12 h-12 rounded-xl bg-slate-100 flex items-center justify-center text-slate-600 hover:bg-black hover:text-white transition-all"
                aria-label="Compartir en X"
              >
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                </svg>
              </a>
              <a 
                href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(`https://platanitorico.com/blog/${post.data.slug}`)}`}
                target="_blank"
                rel="noopener noreferrer"
                class="w-12 h-12 rounded-xl bg-slate-100 flex items-center justify-center text-slate-600 hover:bg-blue-600 hover:text-white transition-all"
                aria-label="Compartir en LinkedIn"
              >
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
              </a>
              <a 
                href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(`https://platanitorico.com/blog/${post.data.slug}`)}`}
                target="_blank"
                rel="noopener noreferrer"
                class="w-12 h-12 rounded-xl bg-slate-100 flex items-center justify-center text-slate-600 hover:bg-blue-800 hover:text-white transition-all"
                aria-label="Compartir en Facebook"
              >
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                </svg>
              </a>
              <button 
                onclick="navigator.clipboard.writeText(window.location.href); alert('Enlace copiado al portapapeles');"
                class="w-12 h-12 rounded-xl bg-slate-100 flex items-center justify-center text-slate-600 hover:bg-orange-500 hover:text-white transition-all"
                aria-label="Copiar enlace"
              >
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3" />
                </svg>
              </button>
            </div>
          </div>
        </div>
      </div>
    </article>

    <!-- CTA Section -->
    <section class="py-24 relative overflow-hidden bg-background">
      <div class="container-premium relative z-10">
        <div class="max-w-6xl mx-auto">
          <div class="relative p-12 md:p-20 rounded-[3rem] bg-dark-900 overflow-hidden shadow-2xl">
            <!-- Decorative Elements -->
            <div class="absolute top-0 right-0 w-80 h-80 bg-yellow-400/20 rounded-full blur-[100px]"></div>
            <div class="absolute bottom-0 left-0 w-64 h-64 bg-nature-400/10 rounded-full blur-[80px]"></div>
            
            <div class="relative text-center max-w-3xl mx-auto">
              <h2 class="text-5xl md:text-6xl font-display text-white mb-8 leading-[0.9]">
                ¿Hablamos de tu próximo proyecto?
              </h2>
              <p class="text-xl text-dark-100 mb-12 leading-relaxed">
                En Platanito Rico te ayudamos con diseño web, marketing digital 
                y soluciones tecnológicas pensadas para destacar y convertir.
              </p>
              
              <div class="flex flex-col sm:flex-row gap-6 justify-center">
                <a 
                  href="/contacto"
                  class="btn-premium px-10 py-5 text-xl"
                >
                  Me interesa
                  <svg class="w-6 h-6 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                  </svg>
                </a>
                <a 
                  href="/servicios"
                  class="btn-secondary px-10 py-5 text-xl bg-white/5 border-white/20 text-white hover:bg-white/10"
                >
                  Nuestros servicios
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- More Articles -->
    <section class="py-24 relative overflow-hidden bg-background">
      <div class="container-premium">
        <div class="max-w-6xl mx-auto">
          <div class="flex items-end justify-between mb-16">
            <div>
              <h2 class="text-5xl md:text-6xl font-display text-dark-900 mb-4 leading-none">
                Sigue leyendo
              </h2>
              <p class="text-xl text-dark-600 font-medium">Más contenido que podría interesarte.</p>
            </div>
            <a 
              href="/blog" 
              class="hidden sm:inline-flex items-center gap-3 font-bold text-dark-800 hover:text-dark-900 transition-all group"
            >
              Ver todo el blog
              <div class="w-12 h-12 rounded-full border-2 border-dark-900/10 flex items-center justify-center group-hover:bg-yellow-400 group-hover:border-yellow-400 transition-all">
                <svg class="w-6 h-6 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </div>
            </a>
          </div>
          
          <div class="grid lg:grid-cols-2 gap-10">
            <a 
              href="/blog"
              class="group p-10 rounded-[2.5rem] bg-blue-200 border border-dark-900/5 hover:border-dark-900/10 hover:shadow-xl transition-all duration-300 flex flex-col h-full"
            >
              <div class="w-16 h-16 rounded-2xl bg-white/50 flex items-center justify-center mb-8 group-hover:scale-110 transition-transform">
                <svg class="w-8 h-8 text-dark-900" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
                </svg>
              </div>
              <h3 class="text-3xl font-display text-dark-900 mb-4 group-hover:translate-x-2 transition-transform">
                Explorar todos los artículos
              </h3>
              <p class="text-lg text-dark-600 leading-relaxed font-medium">
                Descubre más contenido sobre tecnología, SEO y estrategias digitales para impulsar tu negocio.
              </p>
            </a>
            
            <a 
              href="/contacto"
              class="group p-10 rounded-[2.5rem] bg-nature-400 border border-dark-900/5 hover:border-dark-900/10 hover:shadow-xl transition-all duration-300 flex flex-col h-full"
            >
              <div class="w-16 h-16 rounded-2xl bg-white/30 flex items-center justify-center mb-8 group-hover:scale-110 transition-transform">
                <svg class="w-8 h-8 text-dark-900" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
                </svg>
              </div>
              <h3 class="text-3xl font-display text-dark-900 mb-4 group-hover:translate-x-2 transition-transform">
                ¿Buscas algo específico?
              </h3>
              <p class="text-lg text-dark-900/70 leading-relaxed font-medium">
                Si tienes alguna duda o quieres comentarnos tu idea, estamos aquí para escucharte y ayudarte.
              </p>
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
</BaseLayout>

<style is:global>
  /* Prose Styles for Article Content */
  .prose h2 {
    font-family: var(--font-bebas-neue);
    font-size: 3.5rem;
    font-weight: 400;
    color: var(--color-text-primary);
    margin-top: 5rem;
    margin-bottom: 2rem;
    line-height: 0.9;
    letter-spacing: -0.02em;
  }
  
  .prose h3 {
    font-family: var(--font-bebas-neue);
    font-size: 2.5rem;
    font-weight: 400;
    color: var(--color-text-primary);
    margin-top: 4rem;
    margin-bottom: 1.5rem;
    line-height: 1;
  }
  
  .prose h4 {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-text-primary);
    margin-top: 3rem;
    margin-bottom: 1rem;
    letter-spacing: -0.01em;
  }
  
  .prose p {
    margin-bottom: 2rem;
    line-height: 1.7;
    color: var(--color-text-secondary);
    font-size: 1.125rem;
  }
  
  .prose strong {
    color: var(--color-text-primary);
    font-weight: 700;
  }
  
  .prose ul, .prose ol {
    margin-bottom: 2.5rem;
    padding-left: 1.5rem;
  }
  
  .prose li {
    margin-bottom: 0.75rem;
    line-height: 1.7;
    color: var(--color-text-secondary);
  }
  
  .prose a {
    color: var(--color-text-primary);
    text-decoration: underline;
    text-decoration-thickness: 2px;
    text-underline-offset: 4px;
    text-decoration-color: var(--color-cta);
    transition: all 0.2s;
    font-weight: 600;
  }
  
  .prose a:hover {
    text-decoration-color: var(--color-text-primary);
    background: var(--color-cta);
  }
  
  .prose blockquote {
    border-left: 8px solid var(--color-cta);
    padding: 2rem 2.5rem;
    background: var(--color-bg-secondary);
    border-radius: 0 1.5rem 1.5rem 0;
    margin: 4rem 0;
    font-size: 1.5rem;
    line-height: 1.4;
    font-weight: 500;
    color: var(--color-text-primary);
    font-style: normal;
  }
  
  .prose hr {
    border: none;
    border-top: 2px solid var(--border-default);
    margin: 5rem 0;
  }
  
  .prose table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    margin: 4rem 0;
    border: 1px solid var(--border-default);
    border-radius: 1.5rem;
    overflow: hidden;
  }
  
  .prose th {
    background: var(--color-bg-secondary);
    padding: 1.25rem 1.5rem;
    text-align: left;
    font-weight: 700;
    color: var(--color-text-primary);
    border-bottom: 2px solid var(--border-default);
  }
  
  .prose td {
    padding: 1.25rem 1.5rem;
    border-bottom: 1px solid var(--border-default);
    color: var(--color-text-secondary);
  }
  
  .prose tr:last-child td {
    border-bottom: none;
  }
  
  .prose code {
    background: var(--color-bg-tertiary);
    padding: 0.35rem 0.6rem;
    border-radius: 0.5rem;
    font-size: 0.9em;
    color: var(--color-text-primary);
    font-weight: 600;
  }
  
  .prose pre {
    background: var(--color-text);
    padding: 2rem;
    border-radius: 2rem;
    margin: 4rem 0;
  }
  
  .prose pre code {
    background: transparent;
    padding: 0;
    color: #fff;
  }
  
  /* Interactive Cards Helper */
  .prose .grid {
    display: grid;
    gap: 2rem;
    margin: 4rem 0;
  }
  
  /* Highlight Box */
  .prose > div[class*="bg-"] {
    border-radius: 1rem;
    padding: 1.5rem;
    margin: 2rem 0;
  }
</style>
