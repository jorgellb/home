---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';

const audiovisualCategories = [
  {
    title: "Producción de Vídeo (PVP)",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M15 10l4.553-2.276A1 1 0 0 1 21 8.618v6.764a1 1 0 0 1-1.447.894L15 14v-4z"/><rect x="3" y="6" width="12" height="12" rx="2"/></svg>`,
    description: "Cine publicitario y corporativo adaptado a la identidad de tu marca.",
    items: [
      { name: "Vídeo Corporativo Premium (2-3 min)", price: "850€" },
      { name: "Spot Publicitario / Comercial", price: "1200€" },
      { name: "Cobertura de Evento (Jornada)", price: "450€" },
      { name: "Entrevistas / Testimonios (u)", price: "180€" },
      { name: "Drone 4K (Sesión 2h)", price: "250€" },
      { name: "Guionización & Storyboard", price: "200€" }
    ]
  },
  {
    title: "Reels & Vídeo Social",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><path d="M12 18h.01"/></svg>`,
    description: "Contenido vertical de alto impacto para Instagram, TikTok y Shorts.",
    items: [
      { name: "Pack 5 Reels Virales (Edición Pro)", price: "350€" },
      { name: "Vídeo Producto / Unboxing", price: "150€" },
      { name: "Sesión Grabación Reels (4h)", price: "400€" },
      { name: "Edición Reel (Material Cliente)", price: "60€" },
      { name: "Subtitulado Dinámico & FX", price: "40€" }
    ]
  },
  {
    title: "Motion Graphics & Animación",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2a10 10 0 1 0 10 10H12V2z"/><path d="M12 2a10 10 0 0 1 10 10h-10V2z"/><path d="M12 12l9.32-4.26"/></svg>`,
    description: "Animación 2D/3D para explicar conceptos o potenciar tu branding.",
    items: [
      { name: "Logo Animation (Intro/Outro)", price: "200€" },
      { name: "Vídeo Explicativo Animado (60s)", price: "650€" },
      { name: "Infografía Animada Pro", price: "450€" },
      { name: "Intros para YouTube / Streaming", price: "180€" },
      { name: "Postproducción VFX (Por hora)", price: "55€" }
    ]
  },
  {
    title: "Fotografía Profesional",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>`,
    description: "Imagen fija con calidad de estudio para catálogos y web.",
    items: [
      { name: "Sesión Producto (10-15 fotos)", price: "220€" },
      { name: "Retrato Corporativo / Team", price: "180€" },
      { name: "Fotografía de Interiores / Gastro", price: "300€" },
      { name: "Reportaje Evento (Fotos editadas)", price: "350€" },
      { name: "Edición & Retoque High-End (u)", price: "15€" }
    ]
  }
];
---

<BaseLayout
  title="Productora Audiovisual Almería | Vídeo & Fotografía Profesional 2026"
  description="Tarifas oficiales de producción audiovisual en Almería. Vídeo corporativo, reels de impacto, fotografía de producto y motion graphics. Calidad cinematográfica 4K."
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Producción Audiovisual",
    "provider": {
      "@type": "Organization",
      "name": "Platanito Rico",
      "url": "https://platanitorico.com"
    },
    "description": "Servicios de vídeo corporativo, fotografía profesional y motion graphics en Almería.",
    "areaServed": {
      "@type": "State",
      "name": "Almería"
    },
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "Catálogo de Producción Audiovisual",
      "itemListElement": [
        {
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": "Vídeo Corporativo Premium"
          }
        },
        {
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": "Packs Reels Virales"
          }
        }
      ]
    }
  }}
>
  <Header />

  <main class="pt-20">
    <!-- Hero Section -->
    <section class="relative min-h-[60vh] flex items-center justify-center overflow-hidden py-24">
      <div class="absolute inset-0 bg-grid-pattern opacity-10"></div>
      <div class="absolute inset-0 bg-gradient-to-b from-blue-950/20 via-zinc-950/90 to-zinc-950"></div>
      
      <div class="container-premium relative z-10 text-center">
        <div class="badge-premium mb-8 inline-flex animate-fade-up">
          <span class="text-blue-400 font-bold uppercase tracking-[0.2em] text-[10px]">Almería Cinematics</span>
        </div>
        <h1 class="heading-display mb-8 animate-fade-up stagger-1">
          Historias que se ven,
          <span class="block text-gradient mt-2">Marcas que se recuerdan</span>
        </h1>
        <p class="text-xl text-zinc-400 max-w-3xl mx-auto mb-12 animate-fade-up stagger-2 leading-relaxed">
          Somos tu <strong>productora audiovisual en Almería</strong>. Desde el concepto hasta el render final, elevamos la calidad visual de tu negocio con tecnología 4K y narrativa de impacto.
        </p>
        <div class="flex flex-col sm:flex-row justify-center gap-6 animate-fade-up stagger-3">
            <a href="#catalogo" class="btn-premium px-12 !bg-blue-600 hover:!bg-blue-700">Explorar Tarifas</a>
            <a href="#packs" class="btn-premium !bg-emerald-500/10 !border-emerald-500/20 !text-emerald-400 px-12">Packs Producción Total</a>
        </div>
      </div>
    </section>

    <!-- SEO & Authority Section -->
    <section class="py-24 bg-zinc-900/20 relative">
        <div class="container-premium">
            <div class="max-w-4xl mx-auto text-center">
                <h2 class="text-3xl font-black text-white mb-8">Producción de <span class="text-blue-400">Alto Nivel</span> en el Corazón de Almería</h2>
                <p class="text-zinc-400 text-lg leading-relaxed mb-12">
                   Especialistas en <strong>vídeo corporativo</strong>, fotografía publicitaria y contenido dinámico para plataformas sociales. Utilizamos equipamiento de última generación (Red/Blackmagic/Sony) para garantizar un acabado profesional en cada fotograma.
                </p>
                <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                    {["Vídeo 4K/6K", "Drone FPV", "Motion Graphics", "Foto Gastro"].map(tag => (
                        <div class="p-4 rounded-xl bg-white/5 border border-white/10 text-xs font-bold text-zinc-500 uppercase tracking-widest">{tag}</div>
                    ))}
                </div>
            </div>
        </div>
    </section>

    <!-- Complete Catalog -->
    <section id="catalogo" class="section-premium relative">
      <div class="container-premium">
        <div class="text-center mb-24">
            <h2 class="text-5xl font-black text-white mb-6">Catálogo de <span class="text-gradient">Servicios Audiovisuales</span></h2>
            <p class="text-zinc-500 max-w-2xl mx-auto italic">
                Precios base orientativos. Desplazamientos fuera de Almería capital presupuestados de forma independiente.
            </p>
        </div>

        <div class="space-y-32">
            {audiovisualCategories.map((cat, idx) => (
                <div class="animate-fade-up" style={`animation-delay: ${idx * 0.1}s`}>
                    <div class="flex items-center gap-6 mb-12">
                        <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-blue-500 to-cyan-600 p-0.5 shadow-lg shadow-blue-500/20">
                            <div class="w-full h-full rounded-[14px] bg-zinc-950 flex items-center justify-center">
                                <Fragment set:html={cat.icon} />
                            </div>
                        </div>
                        <div>
                            <h3 class="text-3xl font-black text-white mb-2">{cat.title}</h3>
                            <p class="text-zinc-500">{cat.description}</p>
                        </div>
                    </div>

                    <div class="grid md:grid-cols-2 gap-x-12 gap-y-4">
                        {cat.items.map(item => (
                            <div class="flex justify-between items-center py-4 border-b border-white/5 group hover:bg-white/[0.02] px-4 rounded-lg transition-all">
                                <span class="text-sm text-zinc-400 group-hover:text-white transition-colors">{item.name}</span>
                                <div class="flex items-center gap-4">
                                    <span class="text-xs font-bold text-zinc-500 uppercase tracking-widest">Desde</span>
                                    <span class="text-lg font-black text-white">{item.price}</span>
                                </div>
                            </div>
                        ))}
                    </div>
                </div>
            ))}
        </div>
      </div>
    </section>

    <!-- Production Packs -->
    <section id="packs" class="section-premium bg-zinc-950 border-t border-white/5 relative overflow-hidden">
        <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-blue-500/20 to-transparent"></div>
        
        <div class="container-premium text-center mb-24">
            <div class="badge-premium mb-6 bg-emerald-500/10 !text-emerald-400 !border-none">Audiovisual Business</div>
            <h2 class="text-5xl font-black text-white mb-6">Packs de <span class="text-gradient">Producción Recurrente</span></h2>
            <p class="text-zinc-500 max-w-2xl mx-auto text-lg leading-relaxed">Manten tu marca viva con contenido fresco cada mes. Elige tu nivel de compromiso visual.</p>
        </div>

        <div class="container-premium grid md:grid-cols-2 gap-12 max-w-5xl mx-auto">
             <!-- Pack Social Content -->
            <div class="gradient-border-card group relative">
                <div class="gradient-border-card-inner p-12 flex flex-col h-full bg-zinc-900/40 relative">
                    <h4 class="text-zinc-500 uppercase font-black tracking-tighter mb-4 text-sm">Pack Social Creator</h4>
                    <div class="text-6xl font-black text-white mb-2">550€ <span class="text-lg text-zinc-600 font-bold">/ mes</span></div>
                    <p class="text-emerald-400 text-xs font-bold mb-10 uppercase tracking-widest italic">Dominación Social Media</p>
                    
                    <ul class="space-y-6 mb-12 text-left flex-1 border-t border-white/10 pt-10">
                        {[
                            "1 Jornada Grabación (4h)",
                            "8 Reels Editados (Corte & FX)",
                            "10 Fotos de Producto/Local",
                            "Estrategia de Tendencias",
                            "Prioridad de Entrega 48h"
                        ].map(li => (
                            <li class="flex items-start gap-4 text-sm text-zinc-400 italic">
                                <div class="w-5 h-5 rounded-full bg-emerald-500/20 flex items-center justify-center flex-shrink-0 mt-0.5">
                                    <svg class="w-3 h-3 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="4"><path d="M5 13l4 4L19 7"/></svg>
                                </div>
                                {li}
                            </li>
                        ))}
                    </ul>
                    <a href="/#contacto" class="btn-premium !py-5 w-full !bg-blue-600 hover:!bg-blue-700">Contratar Creator</a>
                </div>
            </div>

            <!-- Pack Enterprise VIP -->
            <div class="gradient-border-card group">
                <div class="gradient-border-card-inner p-12 flex flex-col h-full bg-zinc-950/60 relative border-blue-500/20">
                    <div class="absolute -top-4 right-8 bg-blue-600 text-white text-[10px] font-black px-5 py-2 rounded-full shadow-lg shadow-blue-600/30">EL MÁS COMPLETO</div>
                    <h4 class="text-blue-400 uppercase font-black tracking-tighter mb-4 text-sm">Pack Pro Cinema 360</h4>
                    <div class="text-6xl font-black text-white mb-2">1200€ <span class="text-lg text-zinc-600 font-bold">/ mes</span></div>
                    <p class="text-emerald-400 text-xs font-bold mb-10 uppercase tracking-widest italic">Calidad Cine para tu Negocio</p>
                    
                    <ul class="space-y-6 mb-12 text-left flex-1 border-t border-white/10 pt-10">
                        {[
                            "1 Jornada Grabación Completa (8h)",
                            "1 Vídeo Corporativo / Spot Mensual",
                            "12 Reels / Tiktoks Editados",
                            "Sesión Fotografía Ilimitada (Día)",
                            "Tomas de Drone 4K Incluidas",
                            "Motion Graphics & Intro Animada"
                        ].map(li => (
                            <li class="flex items-start gap-4 text-sm text-zinc-300">
                                <div class="w-5 h-5 rounded-full bg-blue-500/20 flex items-center justify-center flex-shrink-0 mt-0.5">
                                    <svg class="w-3 h-3 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="4"><path d="M5 13l4 4L19 7"/></svg>
                                </div>
                                {li}
                            </li>
                        ))}
                    </ul>
                    <a href="/#contacto" class="btn-premium !py-5 w-full bg-gradient-to-r from-blue-600 via-indigo-600 to-indigo-800 border-none shadow-xl shadow-blue-500/20">Activar Pack Cinema</a>
                </div>
            </div>
        </div>
    </section>

    <!-- Contact CTA -->
    <section id="contacto" class="section-premium text-center">
      <div class="container-premium">
        <div class="max-w-3xl mx-auto p-12 rounded-3xl bg-white/[0.02] border border-white/5 backdrop-blur-md">
          <h2 class="text-3xl font-black text-white mb-6">¿Rodamos tu marca?</h2>
          <p class="text-zinc-400 text-lg mb-8 italic">Convertimos tu visión en realidad cinematográfica. Presupuestos a medida en menos de 24h.</p>
          <a href="/#contacto" class="btn-premium px-12 group">
            <span class="flex items-center gap-2">
                Hablar con el Productor
                <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </span>
          </a>
        </div>
      </div>
    </section>

  </main>
  
  <Footer />
</BaseLayout>
