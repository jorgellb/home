---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';

const title = "Soluciones para Agencias | Platanito Rico";
const description = "Tu Partner Tecnológico de confianza. Externaliza el diseño y desarrollo web de tus proyectos con calidad premium y modalidad Marca Blanca.";
---

<BaseLayout title={title} description={description}>
  <Header />

  <main class="relative pt-32 pb-20 overflow-hidden">
    <!-- Background Effects -->
    <div class="absolute inset-0 bg-zinc-950"></div>
    <div class="absolute inset-0 bg-grid-pattern opacity-10"></div>
    <div class="absolute bottom-1/4 left-1/2 -translate-x-1/2 w-[800px] h-[800px] bg-blue-500/10 rounded-full blur-[150px]"></div>

    <div class="container-premium relative z-10">
      <div class="badge-premium mb-6">Agencias & Partners</div>
      <h1 class="heading-display text-left mb-8 animate-fade-up">
        Amplía la capacidad de su equipo con <br/>
        <span class="text-gradient">nuestro respaldo técnico</span>
      </h1>
      
      <div class="grid lg:grid-cols-2 gap-16 items-start">
        <div class="space-y-8 animate-fade-up stagger-1">
          <p class="text-2xl text-zinc-400 leading-relaxed">
            Si tu agencia está <strong class="text-white">"sobrepasada"</strong> o necesitas un especialista en <strong class="text-white">desarrollo de alto rendimiento</strong>, somos tu socio ideal. Trabajamos bajo tu marca para entregar resultados impecables.
          </p>
          
          <div class="space-y-6">
            <h2 class="text-3xl font-bold text-white">Marca Blanca & Colaboración</h2>
            <div class="grid gap-6">
              {[
                {
                  title: "Desarrollo Marca Blanca",
                  desc: "Nos encargamos del código, tú te encargas de la relación con el cliente. Entregamos bajo tu propia identidad."
                },
                {
                  title: "Optimización Core Web Vitals",
                  desc: "Somos expertos en llevar webs lentas a puntuaciones 90+ en Lighthouse para tus clientes exigentes."
                },
                {
                  title: "Mantenimiento Técnico Pro",
                  desc: "Gestionamos la seguridad, backups y actualizaciones de los sitios de tus clientes por ti."
                },
                {
                  title: "Desarrollo a Medida",
                  desc: "Funcionalidades complejas que se salen del alcance habitual de un CMS standard."
                }
              ].map(item => (
                <div class="p-6 rounded-2xl bg-white/[0.02] border border-white/10 hover:border-blue-500/30 transition-colors">
                  <h3 class="text-xl font-bold text-white mb-2">{item.title}</h3>
                  <p class="text-zinc-500">{item.desc}</p>
                </div>
              ))}
            </div>
          </div>
        </div>

        <div class="sticky top-32">
          <div class="p-8 lg:p-12 rounded-3xl bg-gradient-to-br from-white/[0.05] to-transparent border border-white/10 backdrop-blur-xl">
            <h3 class="text-3xl font-bold text-white mb-6">Partnership Estratégico</h3>
            <p class="text-zinc-400 mb-8 text-lg">
              Establecemos acuerdos de colaboración a largo plazo o para proyectos puntuales. Calidad garantizada en cada línea de código.
            </p>
            <a href="/#contacto" class="btn-premium w-full !py-5 text-center justify-center text-xl !bg-blue-600">
              Convertirse en Partner
            </a>
            <p class="mt-6 text-center text-sm text-zinc-500">
              Disponibilidad inmediata para nuevos partners.
            </p>
          </div>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
