---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';

const title = "Soluciones para Emprendedores | Platanito Rico";
const description = "Lanza tu proyecto digital sin complicaciones. Nos encargamos de todo: desde el diseño web hasta el lanzamiento, para que tú te enfoques en tu negocio.";
---

<BaseLayout title={title} description={description}>
  <Header />

  <main class="relative pt-32 pb-20 overflow-hidden">
    <!-- Background Effects -->
    <div class="absolute inset-0 bg-zinc-950"></div>
    <div class="absolute inset-0 bg-grid-pattern opacity-10"></div>
    <div class="absolute top-1/4 -left-64 w-[600px] h-[600px] bg-purple-500/10 rounded-full blur-[120px]"></div>

    <div class="container-premium relative z-10">
      <div class="badge-premium mb-6">Emprendedores</div>
      <h1 class="heading-display text-left mb-8 animate-fade-up">
        De la idea a la <br/>
        <span class="text-gradient">realidad digital</span>
      </h1>
      
      <div class="grid lg:grid-cols-2 gap-16 items-start">
        <div class="space-y-8 animate-fade-up stagger-1">
          <p class="text-2xl text-zinc-400 leading-relaxed">
            Sabemos que como emprendedor, tu tiempo es el activo más valioso. <strong class="text-white">"No tengo tiempo"</strong> o <strong class="text-white">"No sé por dónde empezar"</strong> son frases que escuchamos a diario.
          </p>
          
          <div class="space-y-6">
            <h2 class="text-3xl font-bold text-white">Nuestra solución "Todo Incluido"</h2>
            <div class="grid gap-6">
              {[
                {
                  title: "Diseño y Estrategia",
                  desc: "No solo hacemos una web bonita, creamos una herramienta de venta que comunica tu propuesta de valor."
                },
                {
                  title: "Copywriting Persuasivo",
                  desc: "Redactamos los textos de tu web para que conecten con tu cliente ideal y lo guíen a la acción."
                },
                {
                  title: "Lanzamiento y SEO",
                  desc: "Configuramos todo para que tu sitio sea visible en Google desde el día uno."
                },
                {
                  title: "Formación Básica",
                  desc: "Te enseñamos a gestionar lo básico para que seas dueño de tu propio negocio online."
                }
              ].map(item => (
                <div class="p-6 rounded-2xl bg-white/[0.02] border border-white/10 hover:border-purple-500/30 transition-colors">
                  <h3 class="text-xl font-bold text-white mb-2">{item.title}</h3>
                  <p class="text-zinc-500">{item.desc}</p>
                </div>
              ))}
            </div>
          </div>
        </div>

        <div class="sticky top-32">
          <div class="p-8 lg:p-12 rounded-3xl bg-gradient-to-br from-white/[0.05] to-transparent border border-white/10 backdrop-blur-xl">
            <h3 class="text-3xl font-bold text-white mb-6">¿Hablamos de tu proyecto?</h3>
            <p class="text-zinc-400 mb-8 text-lg">
              Cuéntanos tu idea y te propondremos la ruta más rápida y eficiente para lanzarla al mercado.
            </p>
            <a href="/#contacto" class="btn-premium w-full !py-5 text-center justify-center text-xl">
              Empezar ahora
            </a>
            <p class="mt-6 text-center text-sm text-zinc-500">
              Presupuesto personalizado en menos de 48h.
            </p>
          </div>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
