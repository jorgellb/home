---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';

const title = "Soluciones para Empresas | Platanito Rico";
const description = "Renovamos la presencia digital de tu empresa. Diseño moderno, optimización SEO y una experiencia de usuario que genera confianza y ventas.";
---

<BaseLayout title={title} description={description}>
  <Header />

  <main class="relative pt-32 pb-20 overflow-hidden">
    <!-- Background Effects -->
    <div class="absolute inset-0 bg-zinc-950"></div>
    <div class="absolute inset-0 bg-grid-pattern opacity-10"></div>
    <div class="absolute top-1/4 -right-64 w-[600px] h-[600px] bg-violet-500/10 rounded-full blur-[120px]"></div>

    <div class="container-premium relative z-10">
      <div class="badge-premium mb-6">Empresas</div>
      <h1 class="heading-display text-left mb-8 animate-fade-up">
        Evolución digital de <br/>
        <span class="text-gradient">tu identidad corporativa</span>
      </h1>
      
      <div class="grid lg:grid-cols-2 gap-16 items-start">
        <div class="space-y-8 animate-fade-up stagger-1">
          <p class="text-2xl text-zinc-400 leading-relaxed">
            Una web <strong class="text-white">"que no se ve bien"</strong> o que <strong class="text-white">"parece del siglo pasado"</strong> ahuyenta a potenciales clientes. Tu empresa merece una presencia que transmita profesionalidad y vanguardia.
          </p>
          
          <div class="space-y-6">
            <h2 class="text-3xl font-bold text-white">Renovación Integral</h2>
            <div class="grid gap-6">
              {[
                {
                  title: "Rediseño UI/UX Moderno",
                  desc: "Actualizamos visualmente tu marca con las últimas tendencias de diseño, priorizando la facilidad de uso."
                },
                {
                  title: "Optimización de Rendimiento",
                  desc: "Mejoramos la velocidad de carga para reducir la tasa de rebote y escalar posiciones en buscadores."
                },
                {
                  title: "SEO Local e Internacional",
                  desc: "Estrategias específicas para ser encontrado por los clientes que realmente necesitan tus servicios."
                },
                {
                  title: "Integración de Sistemas",
                  desc: "Conectamos tu web con tu CRM, sistema de reservas o cualquier herramienta que ya utilices."
                }
              ].map(item => (
                <div class="p-6 rounded-2xl bg-white/[0.02] border border-white/10 hover:border-violet-500/30 transition-colors">
                  <h3 class="text-xl font-bold text-white mb-2">{item.title}</h3>
                  <p class="text-zinc-500">{item.desc}</p>
                </div>
              ))}
            </div>
          </div>
        </div>

        <div class="sticky top-32">
          <div class="p-8 lg:p-12 rounded-3xl bg-gradient-to-br from-white/[0.05] to-transparent border border-white/10 backdrop-blur-xl">
            <h3 class="text-3xl font-bold text-white mb-6">Moderniza tu empresa</h3>
            <p class="text-zinc-400 mb-8 text-lg">
              Analizamos tu sitio actual y te proponemos una estrategia de renovación sin comprometer tu imagen establecida.
            </p>
            <a href="/#contacto" class="btn-premium w-full !py-5 text-center justify-center text-xl !bg-violet-600">
              Solicitar Auditoría
            </a>
            <p class="mt-6 text-center text-sm text-zinc-500">
              Auditoría básica gratuita incluida.
            </p>
          </div>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
