---
// Portfolio Section Component - Premium Dark Theme with Real Projects
interface Project {
  id: string;
  name: string;
  description: string;
  category: string;
  url: string;
  image: string;
  gradient: string;
  tags: string[];
}

const projects: Project[] = [
  {
    id: 'clinica-koral',
    name: 'Clinica Dental Koral',
    description: 'Clinica dental en Vera con diseno web premium, SEO multiidioma y sistema de citas online. Tecnologia de vanguardia para una experiencia dental moderna.',
    category: 'Diseno Web + SEO',
    url: 'https://clinicadentalkoral.es/',
    image: '/images/portfolio/clinica-koral.jpg',
    gradient: 'from-cyan-500 to-blue-600',
    tags: ['WordPress', 'SEO', 'Multiidioma']
  },
  {
    id: 'murcia-production',
    name: 'Murcia Production Service',
    description: 'Productora audiovisual especializada en rodajes cinematograficos en Espana. Web corporativa con portfolio de proyectos y servicios de produccion.',
    category: 'Web Corporativa',
    url: 'https://murciaproductionservice.com/',
    image: '/images/portfolio/murcia-production.jpg',
    gradient: 'from-red-500 to-orange-600',
    tags: ['Produccion', 'Cine', 'Audiovisual']
  },
  {
    id: 'actualidad-almanzora',
    name: 'Actualidad Almanzora',
    description: 'Periodico digital lider del Levante de Almeria. Portal de noticias con radio online, podcasts y cobertura local de cultura, agricultura y turismo.',
    category: 'Portal de Noticias',
    url: 'https://www.actualidadalmanzora.es/',
    image: '/images/portfolio/actualidad-almanzora.jpg',
    gradient: 'from-purple-500 to-pink-600',
    tags: ['Noticias', 'Radio', 'Podcast']
  }
];
---

<section class="relative py-28 overflow-hidden" id="portfolio">
  <!-- Background -->
  <div class="absolute inset-0 bg-zinc-950"></div>
  <div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.02)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.02)_1px,transparent_1px)] bg-[size:64px_64px]"></div>
  
  <!-- Glow Orbs -->
  <div class="absolute top-0 left-1/4 w-[600px] h-[600px] bg-purple-500/10 rounded-full blur-[150px]"></div>
  <div class="absolute bottom-0 right-1/4 w-[500px] h-[500px] bg-blue-500/10 rounded-full blur-[150px]"></div>
  
  <div class="relative max-w-7xl mx-auto px-6">
    <!-- Section Header -->
    <div class="text-center mb-20">
      <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/5 border border-white/10 text-sm text-zinc-400 mb-8 animate-fade-up">
        <svg class="w-4 h-4 text-purple-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
        Proyectos destacados
      </span>
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6 animate-fade-up stagger-1">
        Nuestro 
        <span class="text-gradient">Portfolio</span>
      </h2>
      <p class="text-lg md:text-xl text-zinc-400 max-w-2xl mx-auto animate-fade-up stagger-2">
        Proyectos reales que generan resultados. Cada web esta disenada para convertir visitantes en clientes.
      </p>
    </div>
    
    <!-- Portfolio Grid -->
    <div class="grid lg:grid-cols-3 gap-8">
      {projects.map((project, index) => (
        <article 
          class="group relative rounded-3xl bg-white/[0.02] border border-white/10 overflow-hidden hover:border-white/20 transition-all duration-700 animate-fade-up"
          style={`animation-delay: ${0.1 + index * 0.15}s`}
        >
          {/* Image Container with Overlay */}
          <div class="relative aspect-[16/10] overflow-hidden">
            {/* Gradient Placeholder - Replace with actual screenshots */}
            <div class={`absolute inset-0 bg-gradient-to-br ${project.gradient} opacity-20`}></div>
            
            {/* Browser Mockup Frame */}
            <div class="absolute inset-3 rounded-xl overflow-hidden bg-zinc-900 border border-white/10 shadow-2xl group-hover:scale-[1.02] transition-transform duration-700">
              {/* Browser Header */}
              <div class="flex items-center gap-2 px-4 py-3 bg-zinc-800/80 border-b border-white/5">
                <div class="flex gap-1.5">
                  <span class="w-3 h-3 rounded-full bg-red-500/80"></span>
                  <span class="w-3 h-3 rounded-full bg-yellow-500/80"></span>
                  <span class="w-3 h-3 rounded-full bg-green-500/80"></span>
                </div>
                <div class="flex-1 mx-4">
                  <div class="flex items-center gap-2 px-3 py-1.5 rounded-md bg-zinc-700/50 text-xs text-zinc-400">
                    <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                    </svg>
                    <span class="truncate">{project.url.replace('https://', '').replace('www.', '').slice(0, -1)}</span>
                  </div>
                </div>
              </div>
              
              {/* Website Content Preview */}
              <div class={`relative h-[calc(100%-44px)] bg-gradient-to-br ${project.gradient} opacity-30`}>
                {/* Decorative Content Lines */}
                <div class="absolute inset-4 space-y-3">
                  <div class="h-8 w-32 bg-white/20 rounded"></div>
                  <div class="h-4 w-48 bg-white/10 rounded"></div>
                  <div class="h-4 w-40 bg-white/10 rounded"></div>
                  <div class="mt-6 grid grid-cols-3 gap-2">
                    <div class="h-16 bg-white/10 rounded"></div>
                    <div class="h-16 bg-white/10 rounded"></div>
                    <div class="h-16 bg-white/10 rounded"></div>
                  </div>
                </div>
                
                {/* Shine Effect */}
                <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/5 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-1000"></div>
              </div>
            </div>
            
            {/* Floating Category Badge */}
            <div class="absolute top-6 right-6 z-10">
              <span class={`px-3 py-1.5 rounded-full bg-gradient-to-r ${project.gradient} text-white text-xs font-semibold shadow-lg`}>
                {project.category}
              </span>
            </div>
          </div>
          
          {/* Content */}
          <div class="p-6 lg:p-8">
            {/* Project Name */}
            <h3 class="text-xl lg:text-2xl font-bold text-white mb-3 group-hover:text-gradient transition-all duration-300">
              {project.name}
            </h3>
            
            {/* Description */}
            <p class="text-zinc-400 text-sm leading-relaxed mb-5">
              {project.description}
            </p>
            
            {/* Tags */}
            <div class="flex flex-wrap gap-2 mb-6">
              {project.tags.map((tag) => (
                <span class="px-3 py-1 rounded-full bg-white/5 border border-white/10 text-xs text-zinc-400">
                  {tag}
                </span>
              ))}
            </div>
            
            {/* CTA Button */}
            <a 
              href={project.url}
              target="_blank"
              rel="noopener noreferrer"
              class="group/btn inline-flex items-center gap-2 text-white font-medium hover:text-purple-400 transition-colors duration-300"
            >
              <span>Ver proyecto</span>
              <svg class="w-4 h-4 group-hover/btn:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            </a>
          </div>
          
          {/* Hover Glow Effect */}
          <div class={`absolute -inset-px rounded-3xl bg-gradient-to-r ${project.gradient} opacity-0 group-hover:opacity-20 blur-xl transition-opacity duration-700 -z-10`}></div>
        </article>
      ))}
    </div>
    
    <!-- Stats Section -->
    <div class="mt-20 grid grid-cols-2 md:grid-cols-4 gap-6 animate-fade-up" style="animation-delay: 0.6s">
      <div class="text-center p-6 rounded-2xl bg-white/[0.02] border border-white/10">
        <div class="text-3xl lg:text-4xl font-bold text-gradient mb-2">50+</div>
        <div class="text-sm text-zinc-500">Proyectos entregados</div>
      </div>
      <div class="text-center p-6 rounded-2xl bg-white/[0.02] border border-white/10">
        <div class="text-3xl lg:text-4xl font-bold text-gradient mb-2">100%</div>
        <div class="text-sm text-zinc-500">Clientes satisfechos</div>
      </div>
      <div class="text-center p-6 rounded-2xl bg-white/[0.02] border border-white/10">
        <div class="text-3xl lg:text-4xl font-bold text-gradient mb-2">5</div>
        <div class="text-sm text-zinc-500">Anos de experiencia</div>
      </div>
      <div class="text-center p-6 rounded-2xl bg-white/[0.02] border border-white/10">
        <div class="text-3xl lg:text-4xl font-bold text-gradient mb-2">24h</div>
        <div class="text-sm text-zinc-500">Tiempo de respuesta</div>
      </div>
    </div>
    
    <!-- CTA -->
    <div class="mt-16 text-center animate-fade-up" style="animation-delay: 0.7s">
      <p class="text-zinc-400 mb-6">
        ¿Quieres un proyecto como estos?
      </p>
      <a 
        href="/#contacto"
        class="group inline-flex items-center gap-3 px-8 py-4 rounded-full bg-gradient-to-r from-purple-500 to-violet-600 text-white font-semibold hover:shadow-lg hover:shadow-purple-500/30 hover:-translate-y-1 transition-all duration-300"
      >
        <span>Hablemos de tu proyecto</span>
        <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</section>
