---
// Premium Services Section - Ultra Modern with Premium SVG Icons
interface Service {
  id: string;
  data: {
    title: string;
    shortDescription: string;
    features: string[];
    slug: string;
    price?: { amount: number; currency: string; };
  };
}

interface Props {
  services?: Service[];
}

const defaultServices = [
  {
    icon: "code",
    title: "Desarrollo Web",
    description: "Página de aterrizaje optimizada para conversión",
    features: ["Landing Page", "Web Corporativa profesional", "E-commerce con pasarela", "Web App a medida"],
    price: "Desde 50€/mes",
    gradient: "from-blue-500 to-cyan-400"
  },
  {
    icon: "palette",
    title: "Diseño Gráfico",
    description: "Identidad visual y materiales de marketing",
    features: ["Branding completo", "Cartelería gran formato", "Social media kits", "Presentaciones de impacto"],
    price: "Desde 25€",
    gradient: "from-violet-500 to-purple-400"
  },
  {
    icon: "marketing",
    title: "Marketing",
    description: "Posicionamiento en buscadores y estrategias",
    features: ["SEO y posicionamiento", "SEM / Ads", "Gestión Redes Sociales", "Email Marketing auto"],
    price: "Desde 60€",
    gradient: "from-orange-500 to-amber-400"
  },
  {
    icon: "video",
    title: "Audiovisual",
    description: "Producción profesional para empresas",
    features: ["Video Corporativo", "Reels y Shorts verticales", "Motion Graphics", "Fotografía profesional"],
    price: "Desde 15€",
    gradient: "from-rose-500 to-pink-400"
  },
  {
    icon: "music",
    title: "Música",
    description: "Composiciones únicas para tu proyecto",
    features: ["Canciones Personalizadas", "Jingles para marcas", "Producción Musical pro", "Producción de Podcast"],
    price: "Desde 45€",
    gradient: "from-emerald-500 to-teal-400"
  },
  {
    icon: "support",
    title: "Soporte",
    description: "Tu sitio siempre actualizado y seguro",
    features: ["Mantenimiento Web", "Hosting Premium rápido", "Consultoría estratégica", "Formación digital"],
    price: "Desde 50€/mes",
    gradient: "from-indigo-500 to-blue-400"
  }
];

// Premium SVG Icons mapping (Same as Header)
const icons: Record<string, string> = {
  code: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" role="img">
    <path d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/>
  </svg>`,
  
  palette: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" role="img">
    <path d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"/>
  </svg>`,
  
  marketing: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" role="img">
    <path d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
  </svg>`,
  
  video: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" role="img">
    <path d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/>
  </svg>`,
  
  music: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" role="img">
    <path d="M9 18V5l12-2v13M6 21a3 3 0 100-6 3 3 0 000 6zM18 19a3 3 0 100-6 3 3 0 000 6z"/>
  </svg>`,
  
  support: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" role="img">
    <path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
  </svg>`
};
---

<section class="section-premium relative overflow-hidden" id="servicios">
  <!-- Background -->
  <div class="absolute inset-0 bg-grid-pattern opacity-30"></div>
  <div class="absolute inset-0 bg-gradient-to-b from-zinc-950 via-transparent to-zinc-950"></div>
  <div class="glow-orb glow-orb-blue w-[600px] h-[600px] -top-64 right-0 opacity-30"></div>
  <div class="glow-orb glow-orb-purple w-[500px] h-[500px] bottom-0 -left-64 opacity-20"></div>
  
  <div class="container-premium relative z-10">
    <!-- Section Header -->
    <div class="text-center mb-20">
      <div class="badge-premium mb-6 inline-flex animate-fade-up">
        <svg class="w-4 h-4 text-purple-400" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/>
        </svg>
        <span class="ml-2">Servicios Premium</span>
      </div>
      <h2 class="heading-section mb-6 animate-fade-up stagger-1">
        Todo lo que necesitas para
        <span class="block text-gradient mt-2">crecer online</span>
      </h2>
      <p class="text-zinc-400 text-lg md:text-xl max-w-2xl mx-auto animate-fade-up stagger-2">
        Soluciones integrales de diseño y marketing digital para empresas que buscan destacar en el mercado.
      </p>
    </div>
    
    <!-- Services Grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
      {defaultServices.map((service, index) => (
        <article class="gradient-border-card group animate-fade-up" style={`animation-delay: ${0.1 * (index + 1)}s`}>
          <div class="gradient-border-card-inner flex flex-col h-full">
            <!-- Icon -->
            <div class={`w-16 h-16 rounded-2xl bg-gradient-to-br ${service.gradient} p-0.5 mb-6 group-hover:scale-110 group-hover:rotate-3 transition-all duration-500`}>
              <div class="w-full h-full rounded-[14px] bg-zinc-900 flex items-center justify-center">
                <div class="w-8 h-8 text-white" set:html={icons[service.icon]} />
              </div>
            </div>
            
            <!-- Title -->
            <h3 class="text-xl font-bold text-white mb-3 group-hover:text-gradient transition-all duration-300">
              {service.title}
            </h3>
            
            <!-- Description -->
            <p class="text-zinc-400 text-sm mb-6 leading-relaxed">
              {service.description}
            </p>
            
            <!-- Features -->
            <ul class="space-y-3 mb-8 flex-grow">
              {service.features.map((feature: string) => (
                <li class="flex items-center gap-3 text-sm text-zinc-500 group-hover:text-zinc-400 transition-colors">
                  <span class={`w-5 h-5 rounded-full bg-gradient-to-br ${service.gradient} p-0.5 flex-shrink-0`}>
                    <span class="w-full h-full rounded-full bg-zinc-900 flex items-center justify-center">
                      <svg class="w-3 h-3 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                      </svg>
                    </span>
                  </span>
                  {feature}
                </li>
              ))}
            </ul>
            
            <!-- Price & CTA -->
            <div class="flex items-center justify-between pt-6 border-t border-white/10">
              <span class="text-lg font-bold text-gradient">{service.price}</span>
              <a 
                href="/#contacto"
                class="inline-flex items-center text-sm text-zinc-400 hover:text-white transition-colors group/link"
              >
                Solicitar
                <svg class="w-4 h-4 ml-2 group-hover/link:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>
    
    <!-- Bottom CTA -->
    <div class="text-center mt-16 animate-fade-up">
      <div class="inline-flex flex-col sm:flex-row items-center gap-4 p-6 rounded-2xl bg-white/[0.02] border border-white/10">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-purple-500 to-violet-600 flex items-center justify-center">
            <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H8.25m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H12m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 01-2.555-.337A5.972 5.972 0 015.41 20.97a5.969 5.969 0 01-.474-.065 4.48 4.48 0 00.978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25z" />
            </svg>
          </div>
          <div class="text-left">
            <p class="text-white font-medium">¿No encuentras lo que buscas?</p>
            <p class="text-sm text-zinc-500">Creamos soluciones a medida</p>
          </div>
        </div>
        <a href="/#contacto" class="btn-secondary">
          Hablemos
          <svg class="w-4 h-4 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
