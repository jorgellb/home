---

<section class="relative py-28 overflow-hidden" id="tecnologia">
  <!-- Background -->
  <div class="absolute inset-0 bg-zinc-950"></div>
  <div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.015)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.015)_1px,transparent_1px)] bg-[size:72px_72px]"></div>
  
  <!-- Glow Orbs -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[600px] bg-purple-500/5 rounded-full blur-[150px]"></div>
  
  <div class="relative max-w-6xl mx-auto px-6">
    <!-- Section Header -->
    <div class="text-center mb-20">
      <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/5 border border-white/10 text-sm text-zinc-400 mb-8 animate-fade-up">
        <svg class="w-4 h-4 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
        </svg>
        Stack tecnológico
      </span>
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6 animate-fade-up stagger-1">
        Tecnología que 
        <span class="text-gradient">usamos</span>
      </h2>
      <p class="text-lg md:text-xl text-zinc-400 max-w-2xl mx-auto animate-fade-up stagger-2">
        Herramientas modernas y probadas para resultados excepcionales
      </p>
    </div>
    
    <!-- Technologies Grid -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
      {technologies.map((tech, index) => (
        <div 
          class="group relative rounded-2xl bg-white/[0.02] border border-white/10 p-6 hover:bg-white/[0.05] hover:border-white/20 transition-all duration-500 animate-fade-up"
          style={`animation-delay: ${0.1 + index * 0.05}s`}
        >
          <!-- Gradient glow on hover -->
          <div class={`absolute inset-0 rounded-2xl bg-gradient-to-br ${tech.gradient} opacity-0 group-hover:opacity-10 transition-opacity duration-500`}></div>
          
          <div class="relative flex flex-col items-center text-center">
            <!-- Icon container -->
            <div class={`w-16 h-16 rounded-2xl bg-gradient-to-br ${tech.gradient} p-0.5 mb-4 group-hover:scale-110 group-hover:rotate-3 transition-all duration-500`}>
              <div class="w-full h-full rounded-[14px] bg-zinc-900 flex items-center justify-center text-white">
                <Fragment set:html={tech.svg} />
              </div>
            </div>
            
            <!-- Name -->
            <div class="text-white font-semibold mb-1 group-hover:text-gradient transition-all duration-300">
              {tech.name}
            </div>
            
            <!-- Description -->
            <p class="text-sm text-zinc-500 group-hover:text-zinc-400 transition-colors">
              {tech.description}
            </p>
          </div>
        </div>
      ))}
    </div>
    
    <!-- Bottom note -->
    <div class="mt-16 text-center animate-fade-up" style="animation-delay: 0.6s">
      <div class="inline-flex items-center gap-4 px-6 py-4 rounded-2xl bg-white/[0.02] border border-white/10">
        <div class="flex -space-x-2">
          <div class="w-8 h-8 rounded-full bg-gradient-to-br from-purple-500 to-violet-600 flex items-center justify-center text-white text-xs font-bold ring-2 ring-zinc-900">+</div>
          <div class="w-8 h-8 rounded-full bg-gradient-to-br from-blue-500 to-cyan-600 flex items-center justify-center text-white text-xs font-bold ring-2 ring-zinc-900">20</div>
        </div>
        <p class="text-zinc-400">
          Y más de <span class="text-white font-medium">20 herramientas</span> que dominamos
        </p>
      </div>
    </div>
  </div>
</section>
