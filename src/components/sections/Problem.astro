---
// Problem Section Component - Premium Dark Theme with SVG Icons
---

<section class="relative py-28 overflow-hidden" id="problem">
  <!-- Background -->
  <div class="absolute inset-0 bg-zinc-950"></div>
  <div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.015)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.015)_1px,transparent_1px)] bg-[size:72px_72px]"></div>
  
  <!-- Glow Orbs -->
  <div class="glow-orb glow-orb-purple w-[700px] h-[700px] -top-64 -left-64 opacity-40"></div>
  <div class="glow-orb glow-orb-blue w-[600px] h-[600px] -bottom-32 -right-64 opacity-30"></div>
  
  <div class="relative max-w-6xl mx-auto px-6">
    <!-- Section Header -->
    <div class="text-center mb-20">
      <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/5 border border-white/10 text-sm text-zinc-400 mb-8 animate-fade-up">
        <svg class="w-4 h-4 text-purple-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
Identifica tu situación
      </span>
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6 animate-fade-up stagger-1">
        ¿Cuál es tu 
        <span class="text-gradient">caso</span>?
      </h2>
      <p class="text-lg md:text-xl text-zinc-400 max-w-2xl mx-auto animate-fade-up stagger-2">
        Te ayudamos sin importar en qué etapa te encuentres. Identifica tu situación y descubre cómo podemos ayudarte.
      </p>
    </div>
    
    <!-- Cards Grid -->
    <div class="grid md:grid-cols-3 gap-8">
      <!-- Caso 1: Emprendedor -->
      <a 
href="/soluciones/emprendedor/" 
         class="group relative rounded-3xl bg-white/[0.02] border border-white/10 p-8 hover:bg-white/[0.04] hover:border-purple-500/40 transition-all duration-700 animate-fade-up stagger-3 block overflow-hidden"
      >
        <!-- Gradient background on hover -->
        <div class="absolute inset-0 bg-gradient-to-br from-purple-500/20 via-purple-500/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700 pointer-events-none"></div>
        
        <!-- Glow effect -->
        <div class="absolute -inset-px rounded-3xl bg-gradient-to-br from-purple-500/50 to-transparent opacity-0 group-hover:opacity-20 blur-xl transition-opacity duration-700 pointer-events-none"></div>
        
        <div class="relative z-10">
          <!-- Icon -->
          <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-purple-500 to-violet-600 p-0.5 mb-8 group-hover:scale-110 group-hover:rotate-6 transition-all duration-500">
            <div class="w-full h-full rounded-[14px] bg-zinc-900 flex items-center justify-center">
              <svg class="w-8 h-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.59 14.37a6 6 0 01-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 006.16-12.12A14.98 14.98 0 009.631 8.41m5.96 5.96a14.926 14.926 0 01-5.841 2.58m-.119-8.54a6 6 0 00-7.381 5.84h4.8m2.581-5.84a14.927 14.927 0 00-2.58 5.84m2.699 2.7c-.103.021-.207.041-.311.06a15.09 15.09 0 01-2.448-2.448 14.9 14.9 0 01.06-.312m-2.24 2.39a4.493 4.493 0 00-1.757 4.306 4.493 4.493 0 004.306-1.758M16.5 9a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0z" />
              </svg>
            </div>
          </div>
          
          <h3 class="text-2xl font-bold text-white mb-3 group-hover:text-transparent group-hover:bg-clip-text group-hover:bg-gradient-to-r group-hover:from-purple-400 group-hover:to-violet-400 transition-all duration-300">
            Emprendedor
          </h3>
          <p class="text-purple-400 font-medium mb-4 italic text-lg">
            "Abrumado"
          </p>
          <p class="text-zinc-300 mb-4 text-lg">
            "Quiero hacer una web, pero no tengo tiempo"
          </p>
          <p class="text-zinc-500 mb-8">
            Nosotros nos encargamos de todo y te entregamos listo para usar. Sin complicaciones.
          </p>
          <div class="inline-flex items-center text-purple-400 font-semibold group-hover:text-purple-300 transition-colors">
            Ver solución
            <svg class="w-5 h-5 ml-2 group-hover:translate-x-2 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </div>
        </div>
      </a>
      
      <!-- Caso 2: Empresa -->
      <a 
href="/soluciones/empresa/" 
         class="group relative rounded-3xl bg-white/[0.02] border border-white/10 p-8 hover:bg-white/[0.04] hover:border-violet-500/40 transition-all duration-700 animate-fade-up stagger-4 block overflow-hidden"
      >
        <!-- Gradient background on hover -->
        <div class="absolute inset-0 bg-gradient-to-br from-violet-500/20 via-violet-500/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700 pointer-events-none"></div>
        
        <!-- Glow effect -->
        <div class="absolute -inset-px rounded-3xl bg-gradient-to-br from-violet-500/50 to-transparent opacity-0 group-hover:opacity-20 blur-xl transition-opacity duration-700 pointer-events-none"></div>
        
        <div class="relative z-10">
          <!-- Icon -->
          <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-violet-500 to-indigo-600 p-0.5 mb-8 group-hover:scale-110 group-hover:rotate-6 transition-all duration-500">
            <div class="w-full h-full rounded-[14px] bg-zinc-900 flex items-center justify-center">
              <svg class="w-8 h-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99" />
              </svg>
            </div>
          </div>
          
          <h3 class="text-2xl font-bold text-white mb-3 group-hover:text-transparent group-hover:bg-clip-text group-hover:bg-gradient-to-r group-hover:from-violet-400 group-hover:to-indigo-400 transition-all duration-300">
            Empresa
          </h3>
          <p class="text-violet-400 font-medium mb-4 italic text-lg">
            "Desactualizada"
          </p>
          <p class="text-zinc-300 mb-4 text-lg">
            "Mi web está anticuada y no se ve bien"
          </p>
          <p class="text-zinc-500 mb-8">
            Renovamos tu sitio con un diseño moderno, mejoramos el SEO y la experiencia de usuario.
          </p>
          <div class="inline-flex items-center text-violet-400 font-semibold group-hover:text-violet-300 transition-colors">
            Ver solución
            <svg class="w-5 h-5 ml-2 group-hover:translate-x-2 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </div>
        </div>
      </a>
      
      <!-- Caso 3: Agencia -->
      <a 
href="/soluciones/agencia/" 
         class="group relative rounded-3xl bg-white/[0.02] border border-white/10 p-8 hover:bg-white/[0.04] hover:border-blue-500/40 transition-all duration-700 animate-fade-up stagger-5 block overflow-hidden"
      >
        <!-- Gradient background on hover -->
        <div class="absolute inset-0 bg-gradient-to-br from-blue-500/20 via-blue-500/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700 pointer-events-none"></div>
        
        <!-- Glow effect -->
        <div class="absolute -inset-px rounded-3xl bg-gradient-to-br from-blue-500/50 to-transparent opacity-0 group-hover:opacity-20 blur-xl transition-opacity duration-700 pointer-events-none"></div>
        
        <div class="relative z-10">
          <!-- Icon -->
          <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-blue-500 to-cyan-600 p-0.5 mb-8 group-hover:scale-110 group-hover:rotate-6 transition-all duration-500">
            <div class="w-full h-full rounded-[14px] bg-zinc-900 flex items-center justify-center">
              <svg class="w-8 h-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" />
              </svg>
            </div>
          </div>
          
          <h3 class="text-2xl font-bold text-white mb-3 group-hover:text-transparent group-hover:bg-clip-text group-hover:bg-gradient-to-r group-hover:from-blue-400 group-hover:to-cyan-400 transition-all duration-300">
            Agencia
          </h3>
          <p class="text-blue-400 font-medium mb-4 italic text-lg">
            "Sobrepasada"
          </p>
          <p class="text-zinc-300 mb-4 text-lg">
            "Necesito externalizar el diseño web"
          </p>
          <p class="text-zinc-500 mb-8">
            Puedo ser tu socio técnico de confianza para proyectos web. White-label disponible.
          </p>
          <div class="inline-flex items-center text-blue-400 font-semibold group-hover:text-blue-300 transition-colors">
            Ver solución
            <svg class="w-5 h-5 ml-2 group-hover:translate-x-2 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </div>
        </div>
      </a>
    </div>
    
    <!-- Gradient Divider -->
    <div class="mt-24 h-px bg-gradient-to-r from-transparent via-purple-500/50 to-transparent"></div>
  </div>
</section>
