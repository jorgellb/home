---
// Process Section Component - Premium Dark Theme with Timeline & SVG Icons
---

<section class="relative py-28 overflow-hidden" id="proceso">
  <!-- Background -->
  <div class="absolute inset-0 bg-zinc-900"></div>
  <div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.02)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.02)_1px,transparent_1px)] bg-[size:64px_64px]"></div>
  
  <!-- Glow -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-purple-500/5 rounded-full blur-[128px]"></div>
  
  <div class="relative max-w-6xl mx-auto px-6">
    <!-- Section Header -->
    <div class="text-center mb-24">
      <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/5 border border-white/10 text-sm text-zinc-400 mb-8 animate-fade-up">
        <svg class="w-4 h-4 text-violet-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
        </svg>
        Proceso transparente
      </span>
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6 animate-fade-up stagger-1">
        De idea a 
        <span class="text-gradient">lanzamiento</span>
      </h2>
      <p class="text-lg md:text-xl text-zinc-400 max-w-2xl mx-auto animate-fade-up stagger-2">
        5 pasos claros y transparentes para crear tu web perfecta. Sin sorpresas.
      </p>
    </div>
    
    <!-- Timeline -->
    <div class="relative">
      <!-- Vertical Line (Desktop) -->
      <div class="hidden md:block absolute left-1/2 top-0 bottom-0 w-px bg-gradient-to-b from-purple-500 via-violet-500 via-indigo-500 via-blue-500 to-cyan-500 -translate-x-px"></div>
      
      <!-- Mobile Line -->
      <div class="md:hidden absolute left-8 top-0 bottom-0 w-px bg-gradient-to-b from-purple-500 via-violet-500 via-indigo-500 via-blue-500 to-cyan-500"></div>
      
      <!-- Step 1 -->
      <div class="relative flex flex-col md:flex-row items-start md:items-center gap-8 mb-20 animate-fade-up stagger-3">
        <div class="md:w-1/2 md:text-right md:pr-16 order-2 md:order-1 pl-20 md:pl-0">
          <div class="group relative rounded-2xl bg-white/[0.02] border border-white/10 p-8 hover:bg-white/[0.04] hover:border-purple-500/40 transition-all duration-500">
            <div class="absolute inset-0 rounded-2xl bg-gradient-to-br from-purple-500/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
            <div class="relative">
              <h3 class="text-2xl font-bold text-white mb-3">
                Contacto y diagnóstico
              </h3>
              <p class="text-zinc-400 leading-relaxed">
                Cuéntanos tu proyecto y te asesoramos sin compromiso. Analizamos tu mercado y competencia para crear una estrategia ganadora.
              </p>
            </div>
          </div>
        </div>
        <div class="absolute left-0 md:left-1/2 md:-translate-x-1/2 order-1 md:order-2 z-10">
          <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-purple-500 to-violet-600 p-0.5 shadow-lg shadow-purple-500/30">
            <div class="w-full h-full rounded-[14px] bg-zinc-900 flex items-center justify-center">
              <svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 8.511c.884.284 1.5 1.128 1.5 2.097v4.286c0 1.136-.847 2.1-1.98 2.193-.34.027-.68.052-1.02.072v3.091l-3-3c-1.354 0-2.694-.055-4.02-.163a2.115 2.115 0 01-.825-.242m9.345-8.334a2.126 2.126 0 00-.476-.095 48.64 48.64 0 00-8.048 0c-1.131.094-1.976 1.057-1.976 2.192v4.286c0 .837.46 1.58 1.155 1.951m9.345-8.334V6.637c0-1.621-1.152-3.026-2.76-3.235A48.455 48.455 0 0011.25 3c-2.115 0-4.198.137-6.24.402-1.608.209-2.76 1.614-2.76 3.235v6.226c0 1.621 1.152 3.026 2.76 3.235.577.075 1.157.14 1.74.194V21l4.155-4.155" />
              </svg>
            </div>
          </div>
        </div>
        <div class="md:w-1/2 md:pl-16 order-3 hidden md:block"></div>
      </div>
      
      <!-- Step 2 -->
      <div class="relative flex flex-col md:flex-row items-start md:items-center gap-8 mb-20 animate-fade-up stagger-4">
        <div class="md:w-1/2 md:pr-16 order-2 hidden md:block"></div>
        <div class="absolute left-0 md:left-1/2 md:-translate-x-1/2 order-1 z-10">
          <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-violet-500 to-indigo-600 p-0.5 shadow-lg shadow-violet-500/30">
            <div class="w-full h-full rounded-[14px] bg-zinc-900 flex items-center justify-center">
              <svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
              </svg>
            </div>
          </div>
        </div>
        <div class="md:w-1/2 md:text-left md:pl-16 order-3 pl-20 md:pl-16">
          <div class="group relative rounded-2xl bg-white/[0.02] border border-white/10 p-8 hover:bg-white/[0.04] hover:border-violet-500/40 transition-all duration-500">
            <div class="absolute inset-0 rounded-2xl bg-gradient-to-br from-violet-500/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
            <div class="relative">
              <h3 class="text-2xl font-bold text-white mb-3">
                Contenido
              </h3>
              <p class="text-zinc-400 leading-relaxed">
                Reúne y facilítanos tus textos e imágenes. Te guiamos sobre qué necesitas para empezar con buen pie.
              </p>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Step 3 -->
      <div class="relative flex flex-col md:flex-row items-start md:items-center gap-8 mb-20 animate-fade-up stagger-5">
        <div class="md:w-1/2 md:text-right md:pr-16 order-2 md:order-1 pl-20 md:pl-0">
          <div class="group relative rounded-2xl bg-white/[0.02] border border-white/10 p-8 hover:bg-white/[0.04] hover:border-indigo-500/40 transition-all duration-500">
            <div class="absolute inset-0 rounded-2xl bg-gradient-to-br from-indigo-500/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
            <div class="relative">
              <h3 class="text-2xl font-bold text-white mb-3">
                Ejecución
              </h3>
              <p class="text-zinc-400 leading-relaxed">
                Construimos tu solución en menos de 2 semanas con iteraciones rápidas y eficientes. Te mantenemos informado en todo momento.
              </p>
            </div>
          </div>
        </div>
        <div class="absolute left-0 md:left-1/2 md:-translate-x-1/2 order-1 md:order-2 z-10">
          <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-indigo-500 to-blue-600 p-0.5 shadow-lg shadow-indigo-500/30">
            <div class="w-full h-full rounded-[14px] bg-zinc-900 flex items-center justify-center">
              <svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5" />
              </svg>
            </div>
          </div>
        </div>
        <div class="md:w-1/2 md:pl-16 order-3 hidden md:block"></div>
      </div>
      
      <!-- Step 4 -->
      <div class="relative flex flex-col md:flex-row items-start md:items-center gap-8 mb-20 animate-fade-up stagger-6">
        <div class="md:w-1/2 md:pr-16 order-2 hidden md:block"></div>
        <div class="absolute left-0 md:left-1/2 md:-translate-x-1/2 order-1 z-10">
          <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-blue-500 to-cyan-600 p-0.5 shadow-lg shadow-blue-500/30">
            <div class="w-full h-full rounded-[14px] bg-zinc-900 flex items-center justify-center">
              <svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99" />
              </svg>
            </div>
          </div>
        </div>
        <div class="md:w-1/2 md:text-left md:pl-16 order-3 pl-20 md:pl-16">
          <div class="group relative rounded-2xl bg-white/[0.02] border border-white/10 p-8 hover:bg-white/[0.04] hover:border-blue-500/40 transition-all duration-500">
            <div class="absolute inset-0 rounded-2xl bg-gradient-to-br from-blue-500/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
            <div class="relative">
              <h3 class="text-2xl font-bold text-white mb-3">
                Revisiones
              </h3>
              <p class="text-zinc-400 leading-relaxed">
                Tienes dos rondas de ajustes incluidas en el precio para que el resultado cumpla con tus expectativas al 100%.
              </p>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Step 5 -->
      <div class="relative flex flex-col md:flex-row items-start md:items-center gap-8 animate-fade-up">
        <div class="md:w-1/2 md:text-right md:pr-16 order-2 md:order-1 pl-20 md:pl-0">
          <div class="group relative rounded-2xl bg-white/[0.02] border border-white/10 p-8 hover:bg-white/[0.04] hover:border-cyan-500/40 transition-all duration-500">
            <div class="absolute inset-0 rounded-2xl bg-gradient-to-br from-cyan-500/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
            <div class="relative">
              <h3 class="text-2xl font-bold text-white mb-3">
                Lanzamiento
              </h3>
              <p class="text-zinc-400 leading-relaxed">
                Publicamos tu sitio y te entregamos todas las credenciales. Queda listo para usar con documentación completa.
              </p>
            </div>
          </div>
        </div>
        <div class="absolute left-0 md:left-1/2 md:-translate-x-1/2 order-1 md:order-2 z-10">
          <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-cyan-500 to-teal-600 p-0.5 shadow-lg shadow-cyan-500/30">
            <div class="w-full h-full rounded-[14px] bg-zinc-900 flex items-center justify-center">
              <svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.59 14.37a6 6 0 01-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 006.16-12.12A14.98 14.98 0 009.631 8.41m5.96 5.96a14.926 14.926 0 01-5.841 2.58m-.119-8.54a6 6 0 00-7.381 5.84h4.8m2.581-5.84a14.927 14.927 0 00-2.58 5.84m2.699 2.7c-.103.021-.207.041-.311.06a15.09 15.09 0 01-2.448-2.448 14.9 14.9 0 01.06-.312m-2.24 2.39a4.493 4.493 0 00-1.757 4.306 4.493 4.493 0 004.306-1.758M16.5 9a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0z" />
              </svg>
            </div>
          </div>
        </div>
        <div class="md:w-1/2 md:pl-16 order-3 hidden md:block"></div>
      </div>
    </div>
    
    <!-- CTA -->
    <div class="text-center mt-24">
      <a 
        href="/#contacto"
        class="btn-premium group"
      >
        <span class="relative z-10 flex items-center">
          Empezar mi proyecto
          <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </span>
      </a>
    </div>
  </div>
</section>
