</header>

<style is:global>
  /* ============ BOTÓN MÓVIL ============ */
  .mobile-btn-wrapper {
    position: fixed !important;
    top: 16px !important;
    right: 16px !important;
    z-index: 99999 !important;
  }
  
  .mobile-btn-inner {
    position: relative;
    width: 54px;
    height: 54px;
    background: #18181b; /* Fondo sólido para que se vea bien sobre el menú */
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 14px;
    cursor: pointer;
    padding: 0;
    display: flex !important;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 6px; /* Distancia entre líneas */
    transition: all 0.3s ease;
    box-shadow: 0 4px 20px rgba(0,0,0,0.5);
  }

  .mobile-btn-inner:hover {
    border-color: rgba(168, 85, 247, 0.5);
    background: #27272a;
  }
  
  .hamburger-line {
    display: block;
    width: 24px;
    height: 2px;
    background: white;
    border-radius: 2px;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    transform-origin: center;
  }
  
  /* ESTADO ACTIVO (CRUZ) */
  .mobile-btn-inner.is-active {
    background: #27272a;
    border-color: #facc15;
  }

  .mobile-btn-inner.is-active .hamburger-line:nth-child(1) {
    transform: translateY(8px) rotate(45deg);
    background: #facc15;
  }
  
  .mobile-btn-inner.is-active .hamburger-line:nth-child(2) {
    opacity: 0;
    transform: translateX(-10px);
  }
  
  .mobile-btn-inner.is-active .hamburger-line:nth-child(3) {
    transform: translateY(-8px) rotate(-45deg);
    background: #facc15;
  }
  
  @media (min-width: 1024px) {
    .mobile-btn-wrapper { display: none !important; }
  }
  
  /* ============ MENÚ MÓVIL ============ */
  .mobile-overlay {
    position: fixed !important;
    inset: 0 !important;
    z-index: 99998 !important;
    background: #09090b;
    display: flex;
    flex-direction: column;
    transform: translateX(100%);
    transition: transform 0.5s cubic-bezier(0.32, 0.72, 0, 1);
    visibility: hidden;
    overflow: hidden;
  }
  
  .mobile-overlay.is-open {
    transform: translateX(0);
    visibility: visible;
  }
  
  .mobile-overlay.is-open .mobile-nav-link {
    animation: slideIn 0.5s cubic-bezier(0.32, 0.72, 0, 1) forwards;
  }
  
  @keyframes slideIn {
    from { opacity: 0; transform: translateX(30px); }
    to { opacity: 1; transform: translateX(0); }
  }
  
  @media (min-width: 1024px) {
    .mobile-overlay { display: none !important; }
  }
  
  .mobile-overlay-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 20px;
    padding-right: 80px; /* Dejar espacio para el botón fijo */
    border-bottom: 1px solid rgba(255,255,255,0.06);
    min-height: 80px; 
  }
  
  /* Ocultamos el botón cerrar interno ya que usamos el principal */
  #closeMenuBtn {
    display: none !important; 
  }
  
  .mobile-nav {
    flex: 1;
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    overflow-y: auto;
    padding-top: 40px;
  }
  
  .mobile-nav-link {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 16px;
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 20px;
    text-decoration: none;
    transition: all 0.3s ease;
    opacity: 0;
  }
  
  .mobile-nav-link:hover {
    background: rgba(255,255,255,0.05);
    border-color: rgba(168, 85, 247, 0.3);
    transform: translateX(4px);
  }
  
  .mobile-footer {
    padding: 24px 20px;
    border-top: 1px solid rgba(255,255,255,0.06);
    text-align: center;
  }
  
  /* ============ HEADER ============ */
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 80px;
    background: rgba(9,9,11,0.8);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(255,255,255,0.05);
    z-index: 100;
  }
  
  .header-inner {
    max-width: 1280px;
    height: 100%;
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  
  .header-logo {
    display: flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
  }
  
  /* ============ NAV DESKTOP ============ */
  .desktop-nav {
    display: none;
    align-items: center;
    gap: 12px;
  }
  
  @media (min-width: 1024px) {
    .desktop-nav { display: flex; }
  }
  
  .desktop-nav-inner {
    display: flex;
    align-items: center;
    gap: 2px;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.06);
    padding: 6px;
    border-radius: 100px;
  }
  
  .desktop-nav-link {
    position: relative;
    padding: 10px 14px;
    color: #a1a1aa;
    text-decoration: none;
    font-size: 11px; /* Elegancia reducida */
    text-transform: uppercase;
    letter-spacing: 0.15em; /* Tracking amplio premium */
    font-weight: 500;
    transition: all 0.3s;
  }
  
  .desktop-nav-link:hover {
    color: white;
  }
</style>

<script>
  function initMobileMenu() {
    const btn = document.querySelector('.mobile-btn-inner'); // Seleccionamos por clase
    const overlay = document.getElementById('mobileMenuOverlay');

    if (!btn || !overlay) {
        console.error('Elementos menú no encontrados');
        return;
    }

    let isOpen = false;

    function toggleMenu() {
      isOpen = !isOpen;
      
      if (isOpen) {
        overlay.classList.add('is-open');
        btn?.classList.add('is-active'); // Activa animación a cruz
        document.body.style.overflow = 'hidden';
      } else {
        overlay.classList.remove('is-open');
        btn?.classList.remove('is-active'); // Vuelve a hamburguesa
        document.body.style.overflow = '';
      }
    }

    function closeMenu() {
        isOpen = false;
        overlay.classList.remove('is-open');
        btn?.classList.remove('is-active');
        document.body.style.overflow = '';
    }

    // Toggle al hacer click en el botón (sirve para abrir y cerrar)
    btn.onclick = (e) => {
      e.stopPropagation();
      toggleMenu();
    };

    // Cerrar al clickar enlaces
    document.addEventListener('click', (e) => {
        const target = e.target as HTMLElement;
        if (target.closest('.mobile-nav-link')) {
            closeMenu();
        }
    });

    // Cerrar con Escape
    document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closeMenu();
    });
  }

  // Ejecutar
  initMobileMenu();
  document.addEventListener('astro:page-load', initMobileMenu);
</script>
